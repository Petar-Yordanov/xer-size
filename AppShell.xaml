<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="XerSize.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:XerSize.Views.Pages"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            Title="Routines"
            Icon="routines.png"
            Route="routines"
            ContentTemplate="{DataTemplate pages:RoutinesPage}" />

        <ShellContent
            Title="Exercises"
            Icon="exercises.png"
            Route="exercises"
            ContentTemplate="{DataTemplate pages:ExercisesPage}" />

        <ShellContent
            Title="History"
            Icon="history.png"
            Route="history"
            ContentTemplate="{DataTemplate pages:HistoryPage}" />

        <ShellContent
            Title="Statistics"
            Icon="statistics.png"
            Route="statistics"
            ContentTemplate="{DataTemplate pages:StatisticsPage}" />
    </TabBar>
</Shell>