<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XerSize.Views.Pages.ExercisesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewModels="clr-namespace:XerSize.ViewModels.Exercises"
    xmlns:components="clr-namespace:XerSize.Views.Components"
    x:DataType="viewModels:ExercisesPageViewModel"
    x:Name="PageRoot"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    Title="Exercises">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0">
            <Grid Style="{StaticResource PageRootGridStyle}" RowDefinitions="Auto,*">
                <components:Card Grid.Row="0">
                    <VerticalStackLayout Spacing="10">
                        <components:SearchField
                            Text="{Binding SearchText}"
                            Placeholder="Search by name" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <components:SingleSelectDropdown
                                Grid.Column="0"
                                SelectedText="{Binding SelectedForceSummary}"
                                TapCommand="{Binding ToggleForceSheetCommand}" />

                            <components:SingleSelectDropdown
                                Grid.Column="1"
                                SelectedText="{Binding SelectedEquipmentSummary}"
                                TapCommand="{Binding ToggleEquipmentSheetCommand}" />
                        </Grid>

                        <components:SingleSelectDropdown
                            SelectedText="{Binding SelectedBodyCategorySummary}"
                            TapCommand="{Binding ToggleBodyCategorySheetCommand}" />
                    </VerticalStackLayout>
                </components:Card>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <components:Card>
                        <CollectionView
                            ItemsSource="{Binding Items}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureAllItems"
                            EmptyView="No exercises match your filters.">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <Border
                                        Margin="0,0,0,12"
                                        Padding="12"
                                        BackgroundColor="{DynamicResource SurfaceColor}"
                                        Stroke="{DynamicResource BorderColor}"
                                        StrokeThickness="1">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16" />
                                        </Border.StrokeShape>

                                        <VerticalStackLayout Spacing="10">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                <VerticalStackLayout
                                                    Grid.Column="0"
                                                    Spacing="2">
                                                    <Label
                                                        Text="{Binding Name}"
                                                        LineBreakMode="TailTruncation"
                                                        MaxLines="1"
                                                        Style="{StaticResource BodyLabelStyle}" />

                                                    <Label
                                                        Text="{Binding BodyCategory}"
                                                        LineBreakMode="TailTruncation"
                                                        MaxLines="1"
                                                        Style="{StaticResource MutedLabelStyle}" />
                                                </VerticalStackLayout>

                                                <Button
                                                    Grid.Column="1"
                                                    Text="Edit"
                                                    Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.EditCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    MinimumHeightRequest="42"
                                                    Padding="14,10" />
                                            </Grid>

                                            <FlexLayout
                                                Wrap="Wrap"
                                                Direction="Row"
                                                JustifyContent="Start"
                                                AlignItems="Center">
                                                <components:Badge
                                                    Margin="0,0,8,6"
                                                    Text="{Binding Equipment}" />

                                                <components:Badge
                                                    Margin="0,0,8,6"
                                                    Text="{Binding Mechanic}" />

                                                <components:Badge
                                                    Margin="0,0,8,6"
                                                    Text="{Binding Force}" />
                                            </FlexLayout>

                                            <Grid
                                                ColumnDefinitions="Auto,*"
                                                RowDefinitions="Auto,Auto"
                                                ColumnSpacing="8"
                                                RowSpacing="6">

                                                <Label
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Text="Primary:"
                                                    Style="{StaticResource MutedLabelStyle}" />

                                                <Label
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    Text="{Binding PrimaryMusclesText}"
                                                    LineBreakMode="WordWrap"
                                                    Style="{StaticResource BodyLabelStyle}" />

                                                <Label
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Text="Secondary:"
                                                    Style="{StaticResource MutedLabelStyle}" />

                                                <Label
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Text="{Binding SecondaryMusclesText}"
                                                    LineBreakMode="WordWrap"
                                                    Style="{StaticResource BodyLabelStyle}" />
                                            </Grid>

                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                                <components:MetricTile
                                                    Grid.Column="0"
                                                    Title="Equipment"
                                                    Value="{Binding Equipment}" />

                                                <components:MetricTile
                                                    Grid.Column="1"
                                                    Title="Mechanic"
                                                    Value="{Binding Mechanic}" />
                                            </Grid>

                                            <toolkit:Expander
                                                IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                                <toolkit:Expander.Header>
                                                    <Border
                                                        Padding="12"
                                                        BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                                        Stroke="{DynamicResource BorderColor}"
                                                        StrokeThickness="1">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="14" />
                                                        </Border.StrokeShape>

                                                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                                                            <Label
                                                                Text="{Binding ExpandButtonText}"
                                                                VerticalOptions="Center"
                                                                Style="{StaticResource BodyLabelStyle}" />

                                                            <Image
                                                                WidthRequest="16"
                                                                HeightRequest="16"
                                                                Aspect="AspectFit"
                                                                VerticalOptions="Center">
                                                                <Image.Triggers>
                                                                    <DataTrigger TargetType="Image" Binding="{Binding IsExpanded}" Value="True">
                                                                        <Setter Property="Source" Value="expand_less.png" />
                                                                    </DataTrigger>
                                                                    <DataTrigger TargetType="Image" Binding="{Binding IsExpanded}" Value="False">
                                                                        <Setter Property="Source" Value="expand_more.png" />
                                                                    </DataTrigger>
                                                                </Image.Triggers>
                                                            </Image>
                                                        </HorizontalStackLayout>
                                                    </Border>
                                                </toolkit:Expander.Header>

                                                <Border
                                                    Margin="0,8,0,0"
                                                    Padding="12"
                                                    BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                                    StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="14" />
                                                    </Border.StrokeShape>

                                                    <VerticalStackLayout Spacing="8">
                                                        <Label
                                                            Text="Extra Info"
                                                            Style="{StaticResource BodyLabelStyle}" />

                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <Label
                                                                Text="Force:"
                                                                Style="{StaticResource MutedLabelStyle}" />
                                                            <Label
                                                                Grid.Column="1"
                                                                Text="{Binding Force}"
                                                                Style="{StaticResource BodyLabelStyle}" />
                                                        </Grid>

                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <Label
                                                                Text="Body category:"
                                                                Style="{StaticResource MutedLabelStyle}" />
                                                            <Label
                                                                Grid.Column="1"
                                                                Text="{Binding BodyCategory}"
                                                                Style="{StaticResource BodyLabelStyle}" />
                                                        </Grid>

                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <Label
                                                                Text="Primary muscles:"
                                                                Style="{StaticResource MutedLabelStyle}" />
                                                            <Label
                                                                Grid.Column="1"
                                                                Text="{Binding PrimaryMusclesText}"
                                                                Style="{StaticResource BodyLabelStyle}" />
                                                        </Grid>

                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <Label
                                                                Text="Secondary muscles:"
                                                                Style="{StaticResource MutedLabelStyle}" />
                                                            <Label
                                                                Grid.Column="1"
                                                                Text="{Binding SecondaryMusclesText}"
                                                                Style="{StaticResource BodyLabelStyle}" />
                                                        </Grid>

                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <Label
                                                                Text="Limb involvement:"
                                                                Style="{StaticResource MutedLabelStyle}" />
                                                            <Label
                                                                Grid.Column="1"
                                                                Text="{Binding LimbInvolvement}"
                                                                Style="{StaticResource BodyLabelStyle}" />
                                                        </Grid>

                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <Label
                                                                Text="Movement pattern:"
                                                                Style="{StaticResource MutedLabelStyle}" />
                                                            <Label
                                                                Grid.Column="1"
                                                                Text="{Binding MovementPattern}"
                                                                Style="{StaticResource BodyLabelStyle}" />
                                                        </Grid>
                                                    </VerticalStackLayout>
                                                </Border>
                                            </toolkit:Expander>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </components:Card>
                </Grid>
            </Grid>

            <Grid
                IsVisible="{Binding IsForceSheetOpen}"
                InputTransparent="False"
                ZIndex="20">
                <BoxView BackgroundColor="#66000000">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseForceSheetCommand}" />
                    </BoxView.GestureRecognizers>
                </BoxView>

                <Border
                    VerticalOptions="End"
                    Margin="12,0,12,12"
                    Padding="0,12,0,18"
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="10">
                        <BoxView
                            HeightRequest="5"
                            WidthRequest="48"
                            HorizontalOptions="Center"
                            Color="{DynamicResource BorderColor}" />

                        <Label
                            Margin="18,0,18,0"
                            Text="Force"
                            Style="{StaticResource BodyLabelStyle}" />

                        <CollectionView
                            ItemsSource="{Binding ForceOptions}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem"
                            MaximumHeightRequest="340">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <components:SheetOptionRow
                                        Text="{Binding Text}"
                                        IsSelected="{Binding IsSelected}"
                                        TapCommand="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectForceCommand}"
                                        TapCommandParameter="{Binding .}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid
                IsVisible="{Binding IsEquipmentSheetOpen}"
                InputTransparent="False"
                ZIndex="21">
                <BoxView BackgroundColor="#66000000">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseEquipmentSheetCommand}" />
                    </BoxView.GestureRecognizers>
                </BoxView>

                <Border
                    VerticalOptions="End"
                    Margin="12,0,12,12"
                    Padding="0,12,0,18"
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="10">
                        <BoxView
                            HeightRequest="5"
                            WidthRequest="48"
                            HorizontalOptions="Center"
                            Color="{DynamicResource BorderColor}" />

                        <Label
                            Margin="18,0,18,0"
                            Text="Equipment"
                            Style="{StaticResource BodyLabelStyle}" />

                        <CollectionView
                            ItemsSource="{Binding EquipmentOptions}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem"
                            MaximumHeightRequest="340">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <components:SheetOptionRow
                                        Text="{Binding Text}"
                                        IsSelected="{Binding IsSelected}"
                                        TapCommand="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectEquipmentCommand}"
                                        TapCommandParameter="{Binding .}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid
                IsVisible="{Binding IsBodyCategorySheetOpen}"
                InputTransparent="False"
                ZIndex="22">
                <BoxView BackgroundColor="#66000000">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseBodyCategorySheetCommand}" />
                    </BoxView.GestureRecognizers>
                </BoxView>

                <Border
                    VerticalOptions="End"
                    Margin="12,0,12,12"
                    Padding="0,12,0,18"
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="10">
                        <BoxView
                            HeightRequest="5"
                            WidthRequest="48"
                            HorizontalOptions="Center"
                            Color="{DynamicResource BorderColor}" />

                        <Label
                            Margin="18,0,18,0"
                            Text="Body Category"
                            Style="{StaticResource BodyLabelStyle}" />

                        <CollectionView
                            ItemsSource="{Binding BodyCategoryOptions}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem"
                            MaximumHeightRequest="340">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <components:SheetOptionRow
                                        Text="{Binding Text}"
                                        IsSelected="{Binding IsSelected}"
                                        TapCommand="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectBodyCategoryCommand}"
                                        TapCommandParameter="{Binding .}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>

        <components:BottomNavBar Grid.Row="1">
            <HorizontalStackLayout Spacing="4">
                <components:BottomNavBarItem
                    Text="Routines"
                    Icon="routines.png"
                    Route="routines" />

                <components:BottomNavBarItem
                    Text="Exercises"
                    Icon="exercises.png"
                    Route="exercises"
                    IsSelected="True" />

                <components:BottomNavBarItem
                    Text="History"
                    Icon="history.png"
                    Route="history" />

                <components:BottomNavBarItem
                    Text="Stats"
                    Icon="statistics.png"
                    Route="statistics" />

                <components:BottomNavBarItem
                    Text="Settings"
                    Icon="settings.png"
                    Route="settingsTab" />
            </HorizontalStackLayout>
        </components:BottomNavBar>
    </Grid>
</ContentPage>