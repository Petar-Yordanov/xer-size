<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XerSize.Views.Pages.StatisticsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
    xmlns:viewModels="clr-namespace:XerSize.ViewModels.Statistics"
    xmlns:models="clr-namespace:XerSize.Models"
    x:DataType="viewModels:StatisticsPageViewModel"
    Title="Statistics">

    <ScrollView>
        <Grid Style="{StaticResource PageRootGridStyle}" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
            <Label Grid.Row="0" Text="Statistics" Style="{StaticResource PageTitleLabelStyle}" />

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Picker Title="Period" ItemsSource="{Binding AvailableRanges}" SelectedItem="{Binding SelectedRange}" />
                    <Picker Title="Scope" ItemsSource="{Binding AvailableScopes}" SelectedItem="{Binding SelectedScope}" />
                    <Picker Title="Routine" ItemsSource="{Binding Routines}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedRoutine}" />
                    <Picker Title="Workout" ItemsSource="{Binding Workouts}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedWorkout}" />
                </VerticalStackLayout>
            </Border>

            <Grid Grid.Row="2" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout>
                        <Label Text="Workouts" Style="{StaticResource MutedLabelStyle}" />
                        <Label Text="{Binding Snapshot.WorkoutCount}" Style="{StaticResource PageTitleLabelStyle}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout>
                        <Label Text="Total Volume" Style="{StaticResource MutedLabelStyle}" />
                        <Label Text="{Binding Snapshot.TotalVolume, StringFormat='{}{0:F0} kg'}" Style="{StaticResource PageTitleLabelStyle}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout>
                        <Label Text="Total Sets" Style="{StaticResource MutedLabelStyle}" />
                        <Label Text="{Binding Snapshot.TotalSets}" Style="{StaticResource PageTitleLabelStyle}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout>
                        <Label Text="Muscle Groups Hit" Style="{StaticResource MutedLabelStyle}" />
                        <Label Text="{Binding Snapshot.MuscleGroupsHitCount}" Style="{StaticResource PageTitleLabelStyle}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Overall Volume Trend" Style="{StaticResource BodyLabelStyle}" />
                    <lvc:CartesianChart
                        HeightRequest="220"
                        Series="{Binding VolumeSeries}"
                        XAxes="{Binding VolumeXAxes}"
                        YAxes="{Binding VolumeYAxes}" />
                </VerticalStackLayout>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Weight Tracking Over Time" Style="{StaticResource BodyLabelStyle}" />
                    <lvc:CartesianChart
                        HeightRequest="220"
                        Series="{Binding WeightSeries}"
                        XAxes="{Binding WeightXAxes}"
                        YAxes="{Binding WeightYAxes}" />
                </VerticalStackLayout>
            </Border>

            <Border Grid.Row="5" Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Training Preference" Style="{StaticResource BodyLabelStyle}" />
                    <CollectionView ItemsSource="{Binding Snapshot.EquipmentPreference}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:BreakdownItem">
                                <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                    <Label Text="{Binding Label}" Style="{StaticResource MutedLabelStyle}" />
                                    <Label Grid.Column="1" Text="{Binding Value, StringFormat='{}{0:F0}'}" Style="{StaticResource MutedLabelStyle}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <CollectionView ItemsSource="{Binding Snapshot.MechanicPreference}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:BreakdownItem">
                                <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                    <Label Text="{Binding Label}" Style="{StaticResource MutedLabelStyle}" />
                                    <Label Grid.Column="1" Text="{Binding Value, StringFormat='{}{0:F0}'}" Style="{StaticResource MutedLabelStyle}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <CollectionView ItemsSource="{Binding Snapshot.LateralityPreference}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:BreakdownItem">
                                <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                    <Label Text="{Binding Label}" Style="{StaticResource MutedLabelStyle}" />
                                    <Label Grid.Column="1" Text="{Binding Value, StringFormat='{}{0:F0}'}" Style="{StaticResource MutedLabelStyle}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Sets Per Muscle Group" Style="{StaticResource BodyLabelStyle}" />
                    <CollectionView ItemsSource="{Binding Snapshot.SetsPerMuscleGroup}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:BreakdownItem">
                                <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                    <Label Text="{Binding Label}" Style="{StaticResource MutedLabelStyle}" />
                                    <Label Grid.Column="1" Text="{Binding Value, StringFormat='{}{0:F1}'}" Style="{StaticResource MutedLabelStyle}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="Neglected Muscles" Style="{StaticResource BodyLabelStyle}" />
                    <CollectionView ItemsSource="{Binding Snapshot.NeglectedMuscles}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:BreakdownItem">
                                <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                    <Label Text="{Binding Label}" Style="{StaticResource MutedLabelStyle}" />
                                    <Label Grid.Column="1" Text="{Binding Value, StringFormat='{}{0:F1}'}" Style="{StaticResource MutedLabelStyle}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Row="7" Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Plateau Detection" Style="{StaticResource BodyLabelStyle}" />
                    <Label Text="{Binding Snapshot.Plateau.Summary}" Style="{StaticResource MutedLabelStyle}" />
                    <Label Text="{Binding Snapshot.EstimatedCaloriesBurned, StringFormat='Estimated calories: {0:F0} kcal'}" Style="{StaticResource MutedLabelStyle}" />
                    <Label Text="{Binding Snapshot.RestDays, StringFormat='Rest days in range: {0}'}" Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>