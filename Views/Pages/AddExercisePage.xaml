                                <components:SheetOptionRow
                                    Text="{Binding Text}"
                                    IsSelected="{Binding IsSelected}"
                                    TapCommand="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectMovementPatternCommand}"
