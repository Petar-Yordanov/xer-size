<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Name="AddExercisePageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:behaviors="clr-namespace:XerSize.Behaviors"
    xmlns:components="clr-namespace:XerSize.Components"
    xmlns:vm="clr-namespace:XerSize.ViewModels"
    xmlns:options="clr-namespace:XerSize.Models.Presentation.Options"
    xmlns:sets="clr-namespace:XerSize.Models.Presentation.Sets"
    x:Class="XerSize.Views.Pages.AddExercisePage"
    x:DataType="vm:AddExercisePageViewModel"
    Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,18,20,42" Spacing="18">
                <VerticalStackLayout.Behaviors>
                    <behaviors:AppearAnimationBehavior TranslationY="14" Duration="240" />
                </VerticalStackLayout.Behaviors>

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <components:QuickActionChip
                        Grid.Column="0"
                        Size="44"
                        IconSize="18"
                        IconSource="left.png"
                        ChipBackgroundColor="{StaticResource Surface}"
                        Command="{Binding BackCommand}" />

                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                        <Label
                            Text="{Binding PageTitle}"
                            FontFamily="OpenSansSemibold"
                            FontSize="26"
                            TextColor="{StaticResource TextPrimary}" />

                        <Label
                            Text="{Binding PageSubtitle}"
                            Style="{StaticResource SectionSubtitleStyle}" />
                    </VerticalStackLayout>
                </Grid>

                <Border Style="{StaticResource CardBorderStyle}" BackgroundColor="{StaticResource Surface}" Padding="14">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="154,*" ColumnSpacing="14">
                            <Border
                                Grid.Column="0"
                                HeightRequest="178"
                                BackgroundColor="{StaticResource SurfaceSoft}"
                                Stroke="{StaticResource StrokeSoft}"
                                StrokeThickness="1"
                                Padding="10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="24" />
                                </Border.StrokeShape>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PickImageCommand}" />
                                </Border.GestureRecognizers>

                                <VerticalStackLayout Spacing="7" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Image
                                        Source="{Binding SelectedImagePreviewSource}"
                                        WidthRequest="54"
                                        HeightRequest="54"
                                        Aspect="AspectFit"
                                        HorizontalOptions="Center"
                                        InputTransparent="True">
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image" Binding="{Binding HasSelectedImage}" Value="True">
                                                <Setter Property="WidthRequest" Value="132" />
                                                <Setter Property="HeightRequest" Value="128" />
                                                <Setter Property="Aspect" Value="AspectFill" />
                                            </DataTrigger>
                                        </Image.Triggers>
                                    </Image>

                                    <Label
                                        Text="Upload"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="14"
                                        TextColor="{StaticResource TextPrimary}"
                                        HorizontalTextAlignment="Center"
                                        InputTransparent="True">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding HasSelectedImage}" Value="True">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Label
                                        Text="Tap anywhere"
                                        Style="{StaticResource SectionSubtitleStyle}"
                                        FontSize="11"
                                        HorizontalTextAlignment="Center"
                                        InputTransparent="True" />
                                </VerticalStackLayout>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Fill">
                                <components:AppActionButton
                                    HeightRequest="48"
                                    Text="Choose from"
                                    ButtonBackgroundColor="{StaticResource SurfaceSoft}"
                                    ButtonStrokeColor="{StaticResource StrokeSoft}"
                                    ButtonStrokeThickness="1"
                                    TextColor="{StaticResource TextPrimary}"
                                    ShadowOpacity="0"
                                    PressedScale="0.97"
                                    Command="{Binding ChooseFromCommand}" />

                                <components:TextField
                                    Label="Exercise name"
                                    Text="{Binding ExerciseName, Mode=TwoWay}"
                                    Placeholder="Example: Incline Dumbbell Press" />
                            </VerticalStackLayout>
                        </Grid>

                        <components:TextAreaField
                            Label="Notes"
                            Text="{Binding Notes, Mode=TwoWay}"
                            Placeholder="Optional cues, setup notes, form reminders..."
                            MinHeight="92"
                            FieldBackgroundColor="{StaticResource SurfaceSoft}" />

                        <components:MultiSelectField
                            Label="Primary muscle categories"
                            SummaryText="{Binding PrimaryMuscleCategoriesSummary}"
                            HasSelection="{Binding HasPrimaryMuscleCategories}"
                            IsExpanded="{Binding IsPrimaryMuscleCategoriesExpanded, Mode=TwoWay}"
                            ItemsSource="{Binding PrimaryMuscleCategories}"
                            DropdownBackgroundColor="{StaticResource AccentSurface}">
                            <components:MultiSelectField.ItemTemplate>
                                <DataTemplate x:DataType="options:MultiSelectOptionPresentationModel">
                                    <components:MultiSelectOptionRow
                                        Text="{Binding Name}"
                                        IsSelected="{Binding IsSelected}"
                                        Command="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.TogglePrimaryMuscleCategoryCommand}"
                                        CommandParameter="{Binding .}"
                                        SelectedBackgroundColor="{StaticResource AccentSurfaceStrong}"
                                        SelectedStrokeColor="{StaticResource AccentSoft}"
                                        UnselectedBackgroundColor="{StaticResource Surface}"
                                        UnselectedStrokeColor="{StaticResource StrokeSoft}"
                                        SelectedCheckBackgroundColor="{StaticResource Accent}"
                                        UnselectedCheckBackgroundColor="{StaticResource Surface}"
                                        UnselectedCheckStrokeColor="{StaticResource StrokeSoft}"
                                        CheckIconSource="check.png" />
                                </DataTemplate>
                            </components:MultiSelectField.ItemTemplate>
                        </components:MultiSelectField>

                        <components:MultiSelectField
                            Label="Secondary muscle categories"
                            SummaryText="{Binding SecondaryMuscleCategoriesSummary}"
                            HasSelection="{Binding HasSecondaryMuscleCategories}"
                            IsExpanded="{Binding IsSecondaryMuscleCategoriesExpanded, Mode=TwoWay}"
                            ItemsSource="{Binding SecondaryMuscleCategories}"
                            DropdownBackgroundColor="{StaticResource AccentSurface}">
                            <components:MultiSelectField.ItemTemplate>
                                <DataTemplate x:DataType="options:MultiSelectOptionPresentationModel">
                                    <components:MultiSelectOptionRow
                                        Text="{Binding Name}"
                                        IsSelected="{Binding IsSelected}"
                                        Command="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.ToggleSecondaryMuscleCategoryCommand}"
                                        CommandParameter="{Binding .}"
                                        SelectedBackgroundColor="{StaticResource AccentSurfaceStrong}"
                                        SelectedStrokeColor="{StaticResource AccentSoft}"
                                        UnselectedBackgroundColor="{StaticResource Surface}"
                                        UnselectedStrokeColor="{StaticResource StrokeSoft}"
                                        SelectedCheckBackgroundColor="{StaticResource Accent}"
                                        UnselectedCheckBackgroundColor="{StaticResource Surface}"
                                        UnselectedCheckStrokeColor="{StaticResource StrokeSoft}"
                                        CheckIconSource="check.png" />
                                </DataTemplate>
                            </components:MultiSelectField.ItemTemplate>
                        </components:MultiSelectField>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" BackgroundColor="{StaticResource Surface}" Padding="14">
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Sets" FontFamily="OpenSansSemibold" FontSize="18" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding SetInputHelpText}" Style="{StaticResource SectionSubtitleStyle}" />
                        </VerticalStackLayout>

                        <CollectionView ItemsLayout="HorizontalList" SelectionMode="None">
                            <CollectionView.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>dummy</x:String>
                                </x:Array>
                            </CollectionView.ItemsSource>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <HorizontalStackLayout Spacing="10">
                                        <components:TabPill
                                            Text="Weight"
                                            IsSelected="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.IsStrengthTracking}"
                                            Command="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.SelectWeightSetTypeCommand}" />

                                        <components:TabPill
                                            Text="Time"
                                            IsSelected="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.IsTimeTracking}"
                                            Command="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.SelectTimeSetTypeCommand}" />

                                        <components:TabPill
                                            Text="Time + Distance"
                                            IsSelected="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.IsTimeAndDistanceTracking}"
                                            Command="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.SelectTimeAndDistanceSetTypeCommand}" />
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <components:AppDurationField
                            Label="Rest time for all sets"
                            Seconds="{Binding RestSeconds, Mode=TwoWay}"
                            MaximumMinutes="10"
                            FieldBackgroundColor="{StaticResource SurfaceSoft}"
                            TextColorValue="{StaticResource TextPrimary}"
                            IconSource="history.png"
                            IconBackgroundColor="{StaticResource Surface}"
                            IconStrokeColor="{StaticResource StrokeSoft}" />

                        <CollectionView ItemsSource="{Binding Sets}" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="sets:AddEditExerciseSetInputPresentationModel">
                                    <Border BackgroundColor="{StaticResource SurfaceSoft}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" Padding="12">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18" />
                                        </Border.StrokeShape>

                                        <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="10">
                                            <VerticalStackLayout Grid.Column="0" Spacing="6" IsVisible="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.IsStrengthTracking}">
                                                <Label Text="Reps" Style="{StaticResource FieldLabelStyle}" />
                                                <Border Style="{StaticResource InputBorderStyle}" Padding="10,8" BackgroundColor="{StaticResource Surface}">
                                                    <Entry Text="{Binding Reps, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
                                                </Border>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1" Spacing="6" IsVisible="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.IsStrengthTracking}">
                                                <Label Text="Kg" Style="{StaticResource FieldLabelStyle}" />
                                                <Border Style="{StaticResource InputBorderStyle}" Padding="10,8" BackgroundColor="{StaticResource Surface}">
                                                    <Entry Text="{Binding WeightKg, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
                                                </Border>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="0" Spacing="6" IsVisible="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.IsTimeTracking}">
                                                <Label Text="Seconds" Style="{StaticResource FieldLabelStyle}" />
                                                <Border Style="{StaticResource InputBorderStyle}" Padding="10,8" BackgroundColor="{StaticResource Surface}">
                                                    <Entry Text="{Binding DurationSeconds, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
                                                </Border>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="0" Spacing="6" IsVisible="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.IsTimeAndDistanceTracking}">
                                                <Label Text="Seconds" Style="{StaticResource FieldLabelStyle}" />
                                                <Border Style="{StaticResource InputBorderStyle}" Padding="10,8" BackgroundColor="{StaticResource Surface}">
                                                    <Entry Text="{Binding DurationSeconds, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
                                                </Border>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1" Spacing="6" IsVisible="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.IsTimeAndDistanceTracking}">
                                                <Label Text="Km" Style="{StaticResource FieldLabelStyle}" />
                                                <Border Style="{StaticResource InputBorderStyle}" Padding="10,8" BackgroundColor="{StaticResource Surface}">
                                                    <Entry Text="{Binding DistanceKm, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
                                                </Border>
                                            </VerticalStackLayout>

                                            <components:QuickActionChip
                                                Grid.Column="2"
                                                Size="38"
                                                IconSize="16"
                                                IconSource="delete.png"
                                                ChipBackgroundColor="{StaticResource ErrorSurface}"
                                                Command="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.DeleteSetCommand}"
                                                CommandParameter="{Binding .}"
                                                VerticalOptions="End" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <components:AppActionButton
                            Text="Add set"
                            ButtonBackgroundColor="{StaticResource AccentSurface}"
                            ButtonStrokeColor="{StaticResource AccentSoft}"
                            ButtonStrokeThickness="1"
                            TextColor="{StaticResource AccentText}"
                            ShadowOpacity="0"
                            PressedScale="0.97"
                            Command="{Binding AddSetCommand}" />
                    </VerticalStackLayout>
                </Border>

                <toolkit:Expander x:Name="AdvancedExpander" IsExpanded="{Binding IsAdvancedExpanded, Mode=TwoWay}">
                    <toolkit:Expander.Header>
                        <components:SectionExpanderHeader
                            Title="Advanced"
                            Subtitle="Muscles, force, equipment, and movement details"
                            IconSource="settings.png"
                            HeaderBackgroundColor="{StaticResource Surface}"
                            IconBackgroundColor="{StaticResource SurfaceSoft}"
                            IsExpanded="{Binding Source={x:Reference AdvancedExpander}, Path=IsExpanded}" />
                    </toolkit:Expander.Header>

                    <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}" BackgroundColor="{StaticResource Surface}" Padding="14">
                        <VerticalStackLayout Spacing="14">
                            <components:MultiSelectField
                                Label="Primary muscles"
                                SummaryText="{Binding PrimaryMusclesSummary}"
                                HasSelection="{Binding HasPrimaryMuscles}"
                                IsExpanded="{Binding IsPrimaryMusclesExpanded, Mode=TwoWay}"
                                ItemsSource="{Binding PrimaryMuscles}"
                                DropdownBackgroundColor="{StaticResource AccentSurface}">
                                <components:MultiSelectField.ItemTemplate>
                                    <DataTemplate x:DataType="options:MultiSelectOptionPresentationModel">
                                        <components:MultiSelectOptionRow
                                            Text="{Binding Name}"
                                            IsSelected="{Binding IsSelected}"
                                            Command="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.TogglePrimaryMuscleCommand}"
                                            CommandParameter="{Binding .}"
                                            SelectedBackgroundColor="{StaticResource AccentSurfaceStrong}"
                                            SelectedStrokeColor="{StaticResource AccentSoft}"
                                            UnselectedBackgroundColor="{StaticResource Surface}"
                                            UnselectedStrokeColor="{StaticResource StrokeSoft}"
                                            SelectedCheckBackgroundColor="{StaticResource Accent}"
                                            UnselectedCheckBackgroundColor="{StaticResource Surface}"
                                            UnselectedCheckStrokeColor="{StaticResource StrokeSoft}"
                                            CheckIconSource="check.png" />
                                    </DataTemplate>
                                </components:MultiSelectField.ItemTemplate>
                            </components:MultiSelectField>

                            <components:MultiSelectField
                                Label="Secondary muscles"
                                SummaryText="{Binding SecondaryMusclesSummary}"
                                HasSelection="{Binding HasSecondaryMuscles}"
                                IsExpanded="{Binding IsSecondaryMusclesExpanded, Mode=TwoWay}"
                                ItemsSource="{Binding SecondaryMuscles}"
                                DropdownBackgroundColor="{StaticResource AccentSurface}">
                                <components:MultiSelectField.ItemTemplate>
                                    <DataTemplate x:DataType="options:MultiSelectOptionPresentationModel">
                                        <components:MultiSelectOptionRow
                                            Text="{Binding Name}"
                                            IsSelected="{Binding IsSelected}"
                                            Command="{Binding Source={x:Reference AddExercisePageRoot}, Path=BindingContext.ToggleSecondaryMuscleCommand}"
                                            CommandParameter="{Binding .}"
                                            SelectedBackgroundColor="{StaticResource AccentSurfaceStrong}"
                                            SelectedStrokeColor="{StaticResource AccentSoft}"
                                            UnselectedBackgroundColor="{StaticResource Surface}"
                                            UnselectedStrokeColor="{StaticResource StrokeSoft}"
                                            SelectedCheckBackgroundColor="{StaticResource Accent}"
                                            UnselectedCheckBackgroundColor="{StaticResource Surface}"
                                            UnselectedCheckStrokeColor="{StaticResource StrokeSoft}"
                                            CheckIconSource="check.png" />
                                    </DataTemplate>
                                </components:MultiSelectField.ItemTemplate>
                            </components:MultiSelectField>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <components:SingleSelectField
                                    Grid.Column="0"
                                    Label="Force"
                                    Placeholder="Select force"
                                    SelectedText="{Binding SelectedForce, Mode=TwoWay}"
                                    IsExpanded="{Binding IsForceExpanded, Mode=TwoWay}"
                                    ItemsSource="{Binding ForceOptions}"
                                    SelectItemCommand="{Binding SelectForceCommand}"
                                    DropdownBackgroundColor="{StaticResource AccentSurface}" />

                                <components:SingleSelectField
                                    Grid.Column="1"
                                    Label="Body category"
                                    Placeholder="Select body category"
                                    SelectedText="{Binding SelectedBodyCategory, Mode=TwoWay}"
                                    IsExpanded="{Binding IsBodyCategoryExpanded, Mode=TwoWay}"
                                    ItemsSource="{Binding BodyCategoryOptions}"
                                    SelectItemCommand="{Binding SelectBodyCategoryCommand}"
                                    DropdownBackgroundColor="{StaticResource AccentSurface}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <components:SingleSelectField
                                    Grid.Column="0"
                                    Label="Mechanic"
                                    Placeholder="Select mechanic"
                                    SelectedText="{Binding SelectedMechanic, Mode=TwoWay}"
                                    IsExpanded="{Binding IsMechanicExpanded, Mode=TwoWay}"
                                    ItemsSource="{Binding MechanicOptions}"
                                    SelectItemCommand="{Binding SelectMechanicCommand}"
                                    DropdownBackgroundColor="{StaticResource AccentSurface}" />

                                <components:SingleSelectField
                                    Grid.Column="1"
                                    Label="Equipment"
                                    Placeholder="Select equipment"
                                    SelectedText="{Binding SelectedEquipment, Mode=TwoWay}"
                                    IsExpanded="{Binding IsEquipmentExpanded, Mode=TwoWay}"
                                    ItemsSource="{Binding EquipmentOptions}"
                                    SelectItemCommand="{Binding SelectEquipmentCommand}"
                                    DropdownBackgroundColor="{StaticResource AccentSurface}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <components:SingleSelectField
                                    Grid.Column="0"
                                    Label="Limb involvement"
                                    Placeholder="Select limb involvement"
                                    SelectedText="{Binding SelectedLimbInvolvement, Mode=TwoWay}"
                                    IsExpanded="{Binding IsLimbInvolvementExpanded, Mode=TwoWay}"
                                    ItemsSource="{Binding LimbInvolvementOptions}"
                                    SelectItemCommand="{Binding SelectLimbInvolvementCommand}"
                                    DropdownBackgroundColor="{StaticResource AccentSurface}" />

                                <components:SingleSelectField
                                    Grid.Column="1"
                                    Label="Movement pattern"
                                    Placeholder="Select movement pattern"
                                    SelectedText="{Binding SelectedMovementPattern, Mode=TwoWay}"
                                    IsExpanded="{Binding IsMovementPatternExpanded, Mode=TwoWay}"
                                    ItemsSource="{Binding MovementPatternOptions}"
                                    SelectItemCommand="{Binding SelectMovementPatternCommand}"
                                    DropdownBackgroundColor="{StaticResource AccentSurface}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </toolkit:Expander>

                <components:AppActionButton
                    Text="{Binding SaveButtonText}"
                    ButtonBackgroundColor="{StaticResource Accent}"
                    ButtonStrokeColor="Transparent"
                    ButtonStrokeThickness="0"
                    TextColor="{StaticResource White}"
                    ShadowOpacity="0.16"
                    PressedScale="0.97"
                    Command="{Binding SaveExerciseCommand}" />
            </VerticalStackLayout>
        </ScrollView>

        <components:AppDialog
            ZIndex="30"
            IsOpen="{Binding IsValidationErrorVisible}"
            Title="{Binding ValidationErrorTitle}"
            Message="{Binding ValidationErrorMessage}"
            IconSource="delete.png"
            IconBackgroundColor="{StaticResource ErrorSurface}"
            PrimaryButtonText="OK"
            ShowSecondaryButton="False"
            PrimaryCommand="{Binding CloseValidationErrorCommand}"
            DismissCommand="{Binding CloseValidationErrorCommand}" />
    </Grid>
</ContentPage>