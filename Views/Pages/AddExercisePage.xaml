                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <BoxView HeightRequest="5" WidthRequest="48" HorizontalOptions="Center" Color="{DynamicResource BorderColor}" />
                    <Label Margin="18,0,18,0" Text="Limb Involvement" Style="{StaticResource BodyLabelStyle}" />

                    <CollectionView ItemsSource="{Binding LimbInvolvementOptions}" SelectionMode="None" MaximumHeightRequest="340">
