                    <Label Margin="18,0,18,0" Text="Secondary Muscles" Style="{StaticResource BodyLabelStyle}" />

                    <CollectionView ItemsSource="{Binding SecondaryMuscleOptions}" SelectionMode="None" MaximumHeightRequest="340">
