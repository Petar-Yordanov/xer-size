<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Name="HistoryPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:behaviors="clr-namespace:XerSize.Behaviors"
    xmlns:components="clr-namespace:XerSize.Components"
    xmlns:vm="clr-namespace:XerSize.ViewModels"
    xmlns:history="clr-namespace:XerSize.Models.Presentation.History"
    x:Class="XerSize.Views.Pages.HistoryPage"
    x:DataType="vm:HistoryPageViewModel"
    Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,18,20,150" Spacing="18">
                <VerticalStackLayout.Behaviors>
                    <behaviors:AppearAnimationBehavior TranslationY="14" Duration="240" />
                </VerticalStackLayout.Behaviors>

                <VerticalStackLayout Spacing="4">
                    <Label
                        Text="History"
                        FontFamily="OpenSansSemibold"
                        FontSize="30"
                        TextColor="{StaticResource TextPrimary}" />

                    <Label
                        Text="Completed workouts and past sessions"
                        Style="{StaticResource SectionSubtitleStyle}" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <components:MetricTile
                        Grid.Column="0"
                        Title="Completed"
                        Value="{Binding CompletedWorkouts}"
                        Subtitle="Workouts"
                        TileBackgroundColor="{StaticResource AccentSurface}"
                        ValueColor="{StaticResource AccentText}" />

                    <components:MetricTile
                        Grid.Column="1"
                        Title="Time"
                        Value="{Binding TotalTrainingTime}"
                        Subtitle="Total"
                        TileBackgroundColor="{StaticResource InfoSurface}"
                        ValueColor="{StaticResource TextPrimary}" />

                    <components:MetricTile
                        Grid.Column="2"
                        Title="Calories"
                        Value="{Binding TotalCalories}"
                        Subtitle="Estimated"
                        TileBackgroundColor="{StaticResource SuccessSurface}"
                        ValueColor="{StaticResource TextPrimary}" />
                </Grid>

                <Border Style="{StaticResource CardBorderStyle}" BackgroundColor="{StaticResource Surface}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label
                                    Text="Filter"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="16"
                                    TextColor="{StaticResource TextPrimary}" />

                                <Label
                                    Text="Choose a start date and end date"
                                    Style="{StaticResource SectionSubtitleStyle}" />
                            </VerticalStackLayout>

                            <components:AppActionButton
                                Grid.Column="1"
                                Text="Reset"
                                ButtonBackgroundColor="{StaticResource SurfaceSoft}"
                                ButtonStrokeColor="{StaticResource StrokeSoft}"
                                ButtonStrokeThickness="1"
                                TextColor="{StaticResource TextPrimary}"
                                ShadowOpacity="0"
                                PressedScale="0.97"
                                Command="{Binding ResetDateFilterCommand}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <components:AppDateField
                                Grid.Column="0"
                                Label="Start date"
                                Date="{Binding StartDate, Mode=TwoWay}"
                                MaximumDate="{Binding EndDate}"
                                DateFormat="dd MMM yyyy"
                                FieldBackgroundColor="{StaticResource SurfaceSoft}"
                                TextColorValue="{StaticResource TextPrimary}"
                                IconSource="calendar.png"
                                IconBackgroundColor="{StaticResource Surface}"
                                IconStrokeColor="{StaticResource StrokeSoft}" />

                            <components:AppDateField
                                Grid.Column="1"
                                Label="End date"
                                Date="{Binding EndDate, Mode=TwoWay}"
                                MinimumDate="{Binding StartDate}"
                                DateFormat="dd MMM yyyy"
                                FieldBackgroundColor="{StaticResource SurfaceSoft}"
                                TextColorValue="{StaticResource TextPrimary}"
                                IconSource="calendar.png"
                                IconBackgroundColor="{StaticResource Surface}"
                                IconStrokeColor="{StaticResource StrokeSoft}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <CollectionView ItemsSource="{Binding HistoryItems}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.EmptyView>
                        <Border Style="{StaticResource CardBorderStyle}" BackgroundColor="{StaticResource Surface}">
                            <VerticalStackLayout Spacing="8">
                                <Label
                                    Text="No completed workouts in this date range."
                                    FontFamily="OpenSansSemibold"
                                    FontSize="16"
                                    HorizontalTextAlignment="Center" />

                                <Label
                                    Text="Change the start date or end date to see older sessions."
                                    Style="{StaticResource SectionSubtitleStyle}"
                                    HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="history:HistoryWorkoutPresentationModel">
                            <Border Style="{StaticResource CardBorderStyle}" BackgroundColor="{StaticResource Surface}">
                                <VerticalStackLayout Spacing="14">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                Text="{Binding WorkoutName}"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="18"
                                                TextColor="{StaticResource TextPrimary}" />

                                            <Label
                                                Text="{Binding SummaryText}"
                                                Style="{StaticResource SectionSubtitleStyle}" />
                                        </VerticalStackLayout>

                                        <HorizontalStackLayout
                                            Grid.Column="1"
                                            Spacing="8"
                                            HorizontalOptions="End"
                                            VerticalOptions="Start">

                                            <components:StatusBadge
                                                Text="{Binding CompletionStatus}"
                                                BadgeBackgroundColor="{StaticResource SuccessSurface}"
                                                BadgeStrokeColor="#AEE8C9"
                                                BadgeAccentColor="{StaticResource SuccessColor}"
                                                BadgeTextColor="#167A48" />

                                            <components:QuickActionChip
                                                Size="34"
                                                IconSize="14"
                                                IconSource="{Binding ExpandIconSource}"
                                                ChipBackgroundColor="{StaticResource SurfaceSoft}"
                                                Command="{Binding Source={x:Reference HistoryPageRoot}, Path=BindingContext.ToggleHistoryWorkoutCommand}"
                                                CommandParameter="{Binding .}" />
                                        </HorizontalStackLayout>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                        <Border
                                            Grid.Column="0"
                                            BackgroundColor="{StaticResource SurfaceSoft}"
                                            Stroke="{StaticResource StrokeSoft}"
                                            StrokeThickness="1"
                                            Padding="12,10">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="16" />
                                            </Border.StrokeShape>

                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="Date" Style="{StaticResource FieldLabelStyle}" />
                                                <Label Text="{Binding CompletedAtText}" FontFamily="OpenSansSemibold" FontSize="13" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <Border
                                            Grid.Column="1"
                                            BackgroundColor="{StaticResource SurfaceSoft}"
                                            Stroke="{StaticResource StrokeSoft}"
                                            StrokeThickness="1"
                                            Padding="12,10">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="16" />
                                            </Border.StrokeShape>

                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="Calories" Style="{StaticResource FieldLabelStyle}" />
                                                <Label Text="{Binding CaloriesText}" FontFamily="OpenSansSemibold" FontSize="13" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <Border
                                            Grid.Column="2"
                                            BackgroundColor="{StaticResource AccentSurface}"
                                            Stroke="{StaticResource AccentSoft}"
                                            StrokeThickness="1"
                                            Padding="12,10">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="16" />
                                            </Border.StrokeShape>

                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="Volume" Style="{StaticResource FieldLabelStyle}" />
                                                <Label
                                                    Text="{Binding VolumeText}"
                                                    FontFamily="OpenSansSemibold"
                                                    FontSize="13"
                                                    TextColor="{StaticResource AccentText}" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </Grid>

                                    <VerticalStackLayout
                                        Padding="0,2,0,0"
                                        Spacing="10"
                                        IsVisible="{Binding IsExpanded}"
                                        BindableLayout.ItemsSource="{Binding Exercises}">

                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="history:HistoryExercisePresentationModel">
                                                <Border
                                                    BackgroundColor="{StaticResource SurfaceSoft}"
                                                    Stroke="{StaticResource StrokeSoft}"
                                                    StrokeThickness="1"
                                                    Padding="12">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="18" />
                                                    </Border.StrokeShape>

                                                    <VerticalStackLayout Spacing="10">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                            <VerticalStackLayout Spacing="3">
                                                                <Label
                                                                    Text="{Binding Name}"
                                                                    FontFamily="OpenSansSemibold"
                                                                    FontSize="14"
                                                                    TextColor="{StaticResource TextPrimary}" />

                                                                <Label
                                                                    Text="{Binding SummaryText}"
                                                                    Style="{StaticResource SectionSubtitleStyle}" />
                                                            </VerticalStackLayout>

                                                            <HorizontalStackLayout
                                                                Grid.Column="1"
                                                                Spacing="8"
                                                                HorizontalOptions="End"
                                                                VerticalOptions="Start">

                                                                <components:StatusBadge
                                                                    Text="{Binding SetsText}"
                                                                    BadgeBackgroundColor="{StaticResource AccentSurface}"
                                                                    BadgeStrokeColor="{StaticResource AccentSoft}"
                                                                    BadgeAccentColor="{StaticResource Accent}"
                                                                    BadgeTextColor="{StaticResource AccentText}" />

                                                                <components:QuickActionChip
                                                                    Size="32"
                                                                    IconSize="14"
                                                                    IconSource="{Binding ExpandIconSource}"
                                                                    ChipBackgroundColor="{StaticResource Surface}"
                                                                    Command="{Binding Source={x:Reference HistoryPageRoot}, Path=BindingContext.ToggleHistoryExerciseCommand}"
                                                                    CommandParameter="{Binding .}" />
                                                            </HorizontalStackLayout>
                                                        </Grid>

                                                        <FlexLayout
                                                            Padding="0,2,0,0"
                                                            IsVisible="{Binding IsExpanded}"
                                                            Direction="Row"
                                                            Wrap="Wrap"
                                                            AlignItems="Center"
                                                            JustifyContent="Center"
                                                            HorizontalOptions="Center"
                                                            BindableLayout.ItemsSource="{Binding CompletedSets}">

                                                            <BindableLayout.ItemTemplate>
                                                                <DataTemplate x:DataType="history:HistorySetPresentationModel">
                                                                    <components:SetPill
                                                                        Margin="4,0,4,8"
                                                                        Text="{Binding SetText}"
                                                                        BackgroundColorValue="{StaticResource Surface}"
                                                                        StrokeColorValue="{StaticResource StrokeSoft}"
                                                                        TextColorValue="{StaticResource TextPrimary}"
                                                                        HorizontalContentAlignment="Center" />
                                                                </DataTemplate>
                                                            </BindableLayout.ItemTemplate>
                                                        </FlexLayout>
                                                    </VerticalStackLayout>
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>

                                    <Label
                                        Text="{Binding Notes}"
                                        Style="{StaticResource SectionSubtitleStyle}"
                                        IsVisible="{Binding HasNotes}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <Grid
            VerticalOptions="End"
            HorizontalOptions="Fill"
            Margin="20,0,20,18"
            InputTransparent="False">

            <components:BottomNavBarSimple
                LeftPrimaryItem="{Binding DashboardNavItem}"
                LeftSecondaryItem="{Binding WorkoutsNavItem}"
                RightPrimaryItem="{Binding CalendarNavItem}"
                RightSecondaryItem="{Binding SettingsNavItem}"
                ItemCommand="{Binding SelectNavCommand}"
                BarBackgroundColor="{StaticResource Surface}"
                BarStrokeColor="{StaticResource StrokeSoft}"
                BarShadowBrush="#18000000" />
        </Grid>
    </Grid>
</ContentPage>