<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XerSize.Views.Pages.CatalogExercisePickerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:XerSize.ViewModels.Routines"
    xmlns:models="clr-namespace:XerSize.Models"
    x:DataType="viewModels:CatalogExercisePickerPageViewModel"
    x:Name="PageRoot"
    Title="Choose Exercise">

	<Grid Style="{StaticResource PageRootGridStyle}" RowDefinitions="Auto,*">
		<Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
			<VerticalStackLayout Spacing="10">
				<SearchBar Placeholder="Search by name" Text="{Binding SearchText}" />

				<Picker Title="Force" ItemsSource="{Binding ForceOptions}" SelectedItem="{Binding SelectedForce}" />
				<Picker Title="Equipment" ItemsSource="{Binding EquipmentOptions}" SelectedItem="{Binding SelectedEquipment}" />
				<Picker Title="Body Category" ItemsSource="{Binding BodyCategoryOptions}" SelectedItem="{Binding SelectedBodyCategory}" />
			</VerticalStackLayout>
		</Border>

		<CollectionView
            Grid.Row="1"
            Margin="0,12,0,0"
            ItemsSource="{Binding Items}"
            SelectionMode="None"
            EmptyView="No exercises match your filters.">
			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="models:ExerciseCatalogItem">
					<Border
						x:DataType="{x:Null}"
						Margin="0,0,0,10"
						Style="{StaticResource CardBorderStyle}">
						<Border.GestureRecognizers>
							<TapGestureRecognizer
								Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.PickCommand}"
								CommandParameter="{Binding .}" />
						</Border.GestureRecognizers>

						<VerticalStackLayout Spacing="4">
							<Label Text="{Binding Name}" Style="{StaticResource BodyLabelStyle}" />
							<Label Text="{Binding Equipment}" Style="{StaticResource MutedLabelStyle}" />
							<Label Text="{Binding Mechanic}" Style="{StaticResource MutedLabelStyle}" />
							<Label Text="{Binding BodyCategory}" Style="{StaticResource MutedLabelStyle}" />
							<Label Text="{Binding Force}" Style="{StaticResource MutedLabelStyle}" />
						</VerticalStackLayout>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>
	</Grid>
</ContentPage>