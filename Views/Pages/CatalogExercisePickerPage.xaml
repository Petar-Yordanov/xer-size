<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XerSize.Views.Pages.CatalogExercisePickerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:XerSize.ViewModels.Routines"
    xmlns:components="clr-namespace:XerSize.Views.Components"
    x:DataType="viewModels:CatalogExercisePickerPageViewModel"
    x:Name="PageRoot"
    Title="Choose Exercise">

    <Grid>
        <Grid Style="{StaticResource PageRootGridStyle}" RowDefinitions="Auto,*">
            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <SearchBar
                        Placeholder="Search by name"
                        Text="{Binding SearchText}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <components:SingleSelectDropdown
                            Grid.Column="0"
                            SelectedText="{Binding SelectedForceSummary}"
                            TapCommand="{Binding ToggleForceSheetCommand}"
                            TrailingIconText="v" />

                        <components:SingleSelectDropdown
                            Grid.Column="1"
                            SelectedText="{Binding SelectedEquipmentSummary}"
                            TapCommand="{Binding ToggleEquipmentSheetCommand}"
                            TrailingIconText="v" />
                    </Grid>

                    <components:SingleSelectDropdown
                        SelectedText="{Binding SelectedBodyCategorySummary}"
                        TapCommand="{Binding ToggleBodyCategorySheetCommand}"
                        TrailingIconText="v" />
                </VerticalStackLayout>
            </Border>

            <CollectionView
                Grid.Row="1"
                Margin="0,12,0,0"
                ItemsSource="{Binding Items}"
                SelectionMode="None"
                EmptyView="No exercises match your filters.">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:CatalogExerciseCardRow">
                        <Border
                            x:DataType="{x:Null}"
                            Margin="0,0,0,10"
                            Style="{StaticResource CardBorderStyle}">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <Label
                                        Grid.Column="0"
                                        Text="{Binding Name}"
                                        Style="{StaticResource BodyLabelStyle}" />

                                    <Button
                                        Grid.Column="1"
                                        Padding="12,8"
                                        Text="Choose"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.PickCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Label
                                        Text="Primary:"
                                        Style="{StaticResource MutedLabelStyle}" />
                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding PrimaryMusclesText}"
                                        Style="{StaticResource BodyLabelStyle}" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Label
                                        Text="Secondary:"
                                        Style="{StaticResource MutedLabelStyle}" />
                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding SecondaryMusclesText}"
                                        Style="{StaticResource BodyLabelStyle}" />
                                </Grid>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Border
                                        Grid.Column="0"
                                        Padding="10,8"
                                        BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                        StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>

                                        <VerticalStackLayout Spacing="2">
                                            <Label
                                                Text="Equipment"
                                                Style="{StaticResource MutedLabelStyle}" />
                                            <Label
                                                Text="{Binding Equipment}"
                                                Style="{StaticResource BodyLabelStyle}" />
                                        </VerticalStackLayout>
                                    </Border>

                                    <Border
                                        Grid.Column="1"
                                        Padding="10,8"
                                        BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                        StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>

                                        <VerticalStackLayout Spacing="2">
                                            <Label
                                                Text="Mechanic"
                                                Style="{StaticResource MutedLabelStyle}" />
                                            <Label
                                                Text="{Binding Mechanic}"
                                                Style="{StaticResource BodyLabelStyle}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>

                                <Button
                                    Text="{Binding ExpandButtonText}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.ToggleExpandedCommand}"
                                    CommandParameter="{Binding .}" />

                                <Border
                                    IsVisible="{Binding IsExpanded}"
                                    Padding="12"
                                    BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>

                                    <VerticalStackLayout Spacing="8">
                                        <Label
                                            Text="Extra Info"
                                            Style="{StaticResource BodyLabelStyle}" />

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Label
                                                Text="Force:"
                                                Style="{StaticResource MutedLabelStyle}" />
                                            <Label
                                                Grid.Column="1"
                                                Text="{Binding Force}"
                                                Style="{StaticResource BodyLabelStyle}" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Label
                                                Text="Body category:"
                                                Style="{StaticResource MutedLabelStyle}" />
                                            <Label
                                                Grid.Column="1"
                                                Text="{Binding BodyCategory}"
                                                Style="{StaticResource BodyLabelStyle}" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Label
                                                Text="Limb involvement:"
                                                Style="{StaticResource MutedLabelStyle}" />
                                            <Label
                                                Grid.Column="1"
                                                Text="{Binding LimbInvolvement}"
                                                Style="{StaticResource BodyLabelStyle}" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Label
                                                Text="Movement pattern:"
                                                Style="{StaticResource MutedLabelStyle}" />
                                            <Label
                                                Grid.Column="1"
                                                Text="{Binding MovementPattern}"
                                                Style="{StaticResource BodyLabelStyle}" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <Grid
            IsVisible="{Binding IsForceSheetOpen}"
            InputTransparent="False"
            ZIndex="20">

            <BoxView BackgroundColor="#66000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseForceSheetCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border
                VerticalOptions="End"
                Margin="12,0,12,12"
                Padding="0,12,0,18"
                BackgroundColor="{DynamicResource SurfaceColor}"
                Stroke="{DynamicResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <BoxView
                        HeightRequest="5"
                        WidthRequest="48"
                        HorizontalOptions="Center"
                        Color="{DynamicResource BorderColor}" />

                    <Label
                        Margin="18,0,18,0"
                        Text="Force"
                        Style="{StaticResource BodyLabelStyle}" />

                    <CollectionView
                        ItemsSource="{Binding ForceOptions}"
                        SelectionMode="None"
                        MaximumHeightRequest="340">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="{x:Null}">
                                <Border
                                    Margin="12,0,12,8"
                                    Padding="14,12"
                                    BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectForceCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label
                                            Text="{Binding Text}"
                                            VerticalOptions="Center"
                                            Style="{StaticResource BodyLabelStyle}" />

                                        <Label
                                            Grid.Column="1"
                                            Text="✓"
                                            VerticalOptions="Center"
                                            IsVisible="{Binding IsSelected}"
                                            Style="{StaticResource BodyLabelStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid
            IsVisible="{Binding IsEquipmentSheetOpen}"
            InputTransparent="False"
            ZIndex="21">

            <BoxView BackgroundColor="#66000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseEquipmentSheetCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border
                VerticalOptions="End"
                Margin="12,0,12,12"
                Padding="0,12,0,18"
                BackgroundColor="{DynamicResource SurfaceColor}"
                Stroke="{DynamicResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <BoxView
                        HeightRequest="5"
                        WidthRequest="48"
                        HorizontalOptions="Center"
                        Color="{DynamicResource BorderColor}" />

                    <Label
                        Margin="18,0,18,0"
                        Text="Equipment"
                        Style="{StaticResource BodyLabelStyle}" />

                    <CollectionView
                        ItemsSource="{Binding EquipmentOptions}"
                        SelectionMode="None"
                        MaximumHeightRequest="340">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="{x:Null}">
                                <Border
                                    Margin="12,0,12,8"
                                    Padding="14,12"
                                    BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectEquipmentCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label
                                            Text="{Binding Text}"
                                            VerticalOptions="Center"
                                            Style="{StaticResource BodyLabelStyle}" />

                                        <Label
                                            Grid.Column="1"
                                            Text="✓"
                                            VerticalOptions="Center"
                                            IsVisible="{Binding IsSelected}"
                                            Style="{StaticResource BodyLabelStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid
            IsVisible="{Binding IsBodyCategorySheetOpen}"
            InputTransparent="False"
            ZIndex="22">

            <BoxView BackgroundColor="#66000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseBodyCategorySheetCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border
                VerticalOptions="End"
                Margin="12,0,12,12"
                Padding="0,12,0,18"
                BackgroundColor="{DynamicResource SurfaceColor}"
                Stroke="{DynamicResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <BoxView
                        HeightRequest="5"
                        WidthRequest="48"
                        HorizontalOptions="Center"
                        Color="{DynamicResource BorderColor}" />

                    <Label
                        Margin="18,0,18,0"
                        Text="Body Category"
                        Style="{StaticResource BodyLabelStyle}" />

                    <CollectionView
                        ItemsSource="{Binding BodyCategoryOptions}"
                        SelectionMode="None"
                        MaximumHeightRequest="340">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="{x:Null}">
                                <Border
                                    Margin="12,0,12,8"
                                    Padding="14,12"
                                    BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectBodyCategoryCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label
                                            Text="{Binding Text}"
                                            VerticalOptions="Center"
                                            Style="{StaticResource BodyLabelStyle}" />

                                        <Label
                                            Grid.Column="1"
                                            Text="✓"
                                            VerticalOptions="Center"
                                            IsVisible="{Binding IsSelected}"
                                            Style="{StaticResource BodyLabelStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>