<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Name="CatalogPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:XerSize.Components"
    xmlns:vm="clr-namespace:XerSize.ViewModels"
    xmlns:catalog="clr-namespace:XerSize.Models.Presentation.Catalog"
    x:Class="XerSize.Views.Pages.CatalogExercisePickerPage"
    x:DataType="vm:CatalogExercisePickerPageViewModel"
    Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,18,20,42" Spacing="16">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <components:QuickActionChip
                        Grid.Column="0"
                        Size="44"
                        IconSize="18"
                        IconSource="left.png"
                        ChipBackgroundColor="{StaticResource Surface}"
                        Command="{Binding BackCommand}" />

                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                        <Label Text="Exercise catalog" FontFamily="OpenSansSemibold" FontSize="26" TextColor="{StaticResource TextPrimary}" />
                        <Label Text="Search and choose an exercise" Style="{StaticResource SectionSubtitleStyle}" />
                    </VerticalStackLayout>

                    <components:QuickActionChip
                        Grid.Column="2"
                        Size="44"
                        IconSize="18"
                        IconSource="delete.png"
                        ChipBackgroundColor="{StaticResource Surface}"
                        Command="{Binding ClearFiltersCommand}" />
                </Grid>

                <components:SearchField
                    Text="{Binding SearchText, Mode=TwoWay}"
                    Placeholder="Search by name, muscle, equipment..."
                    IconSource="search.png" />

                <Border IsVisible="{Binding IsLoading}" Style="{StaticResource SoftCardBorderStyle}" BackgroundColor="{StaticResource SurfaceSoft}">
                    <Label Text="Loading catalog..." Style="{StaticResource SectionSubtitleStyle}" HorizontalTextAlignment="Center" />
                </Border>

                <Border IsVisible="{Binding HasCatalogLoadError}" Style="{StaticResource CardBorderStyle}" BackgroundColor="{StaticResource ErrorSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Catalog could not load" FontFamily="OpenSansSemibold" FontSize="16" TextColor="{StaticResource TextPrimary}" HorizontalTextAlignment="Center" />
                        <Label Text="{Binding CatalogLoadErrorMessage}" Style="{StaticResource SectionSubtitleStyle}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" IsVisible="{Binding HasNoCatalogLoadError}">
                    <Label Grid.Column="0" Text="{Binding ResultCountText}" Style="{StaticResource SectionSubtitleStyle}" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="More available" Style="{StaticResource FieldLabelStyle}" VerticalOptions="Center" IsVisible="{Binding CanLoadMore}" />
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsVisible="{Binding HasNoCatalogLoadError}">
                    <components:SingleSelectField
                        Grid.Column="0"
                        Label="Force"
                        Placeholder="All"
                        SelectedText="{Binding SelectedForce, Mode=TwoWay}"
                        IsExpanded="{Binding IsForceExpanded, Mode=TwoWay}"
                        ItemsSource="{Binding ForceOptions}"
                        SelectItemCommand="{Binding SelectForceCommand}"
                        DropdownBackgroundColor="{StaticResource AccentSurface}" />

                    <components:SingleSelectField
                        Grid.Column="1"
                        Label="Category"
                        Placeholder="All"
                        SelectedText="{Binding SelectedBodyCategory, Mode=TwoWay}"
                        IsExpanded="{Binding IsBodyCategoryExpanded, Mode=TwoWay}"
                        ItemsSource="{Binding BodyCategoryOptions}"
                        SelectItemCommand="{Binding SelectBodyCategoryCommand}"
                        DropdownBackgroundColor="{StaticResource AccentSurface}" />
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsVisible="{Binding HasNoCatalogLoadError}">
                    <components:SingleSelectField
                        Grid.Column="0"
                        Label="Mechanic"
                        Placeholder="All"
                        SelectedText="{Binding SelectedMechanic, Mode=TwoWay}"
                        IsExpanded="{Binding IsMechanicExpanded, Mode=TwoWay}"
                        ItemsSource="{Binding MechanicOptions}"
                        SelectItemCommand="{Binding SelectMechanicCommand}"
                        DropdownBackgroundColor="{StaticResource AccentSurface}" />

                    <components:SingleSelectField
                        Grid.Column="1"
                        Label="Equipment"
                        Placeholder="All"
                        SelectedText="{Binding SelectedEquipment, Mode=TwoWay}"
                        IsExpanded="{Binding IsEquipmentExpanded, Mode=TwoWay}"
                        ItemsSource="{Binding EquipmentOptions}"
                        SelectItemCommand="{Binding SelectEquipmentCommand}"
                        DropdownBackgroundColor="{StaticResource AccentSurface}" />
                </Grid>

                <components:SingleSelectField
                    IsVisible="{Binding HasNoCatalogLoadError}"
                    Label="Limb involvement"
                    Placeholder="All"
                    SelectedText="{Binding SelectedLimbInvolvement, Mode=TwoWay}"
                    IsExpanded="{Binding IsLimbInvolvementExpanded, Mode=TwoWay}"
                    ItemsSource="{Binding LimbInvolvementOptions}"
                    SelectItemCommand="{Binding SelectLimbInvolvementCommand}"
                    DropdownBackgroundColor="{StaticResource AccentSurface}" />

                <CollectionView ItemsSource="{Binding FilteredExercises}" SelectionMode="None" IsVisible="{Binding HasNoCatalogLoadError}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.EmptyView>
                        <Border Style="{StaticResource CardBorderStyle}" BackgroundColor="{StaticResource Surface}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="No exercises found." FontFamily="OpenSansSemibold" FontSize="16" HorizontalTextAlignment="Center" />
                                <Label Text="Change your search or filters." Style="{StaticResource SectionSubtitleStyle}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="catalog:ExerciseCatalogItemPresentationModel">
                            <Border Style="{StaticResource CardBorderStyle}" BackgroundColor="{StaticResource Surface}" Padding="14">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference CatalogPageRoot}, Path=BindingContext.SelectExerciseCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding Name}" FontFamily="OpenSansSemibold" FontSize="17" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding Metadata.BodyCategoryText}" Style="{StaticResource SectionSubtitleStyle}" />

                                    <FlexLayout Direction="Row" Wrap="Wrap" BindableLayout.ItemsSource="{Binding Metadata.PrimaryMuscleCategories}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <components:SetPill
                                                    Margin="0,0,6,6"
                                                    Text="{Binding .}"
                                                    BackgroundColorValue="{StaticResource AccentSurface}"
                                                    StrokeColorValue="{StaticResource AccentSoft}"
                                                    TextColorValue="{StaticResource AccentText}" />
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </FlexLayout>

                                    <Label Text="{Binding Metadata.EquipmentText, StringFormat='Equipment: {0}'}" Style="{StaticResource SectionSubtitleStyle}" />
                                    <Label Text="{Binding Metadata.MechanicText, StringFormat='Mechanic: {0}'}" Style="{StaticResource SectionSubtitleStyle}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <components:AppActionButton
                    Text="Load more"
                    IsVisible="{Binding CanLoadMore}"
                    ButtonBackgroundColor="{StaticResource AccentSurface}"
                    ButtonStrokeColor="{StaticResource AccentSoft}"
                    ButtonStrokeThickness="1"
                    TextColor="{StaticResource AccentText}"
                    ShadowOpacity="0"
                    PressedScale="0.97"
                    Command="{Binding LoadMoreCommand}" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>