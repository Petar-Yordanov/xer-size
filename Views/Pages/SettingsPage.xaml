<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Name="SettingsPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:behaviors="clr-namespace:XerSize.Behaviors"
    xmlns:components="clr-namespace:XerSize.Components"
    xmlns:vm="clr-namespace:XerSize.ViewModels"
    x:Class="XerSize.Views.Pages.SettingsPage"
    x:DataType="vm:SettingsPageViewModel"
    Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,18,20,150" Spacing="18">
                <VerticalStackLayout.Behaviors>
                    <behaviors:AppearAnimationBehavior TranslationY="14" Duration="240" />
                </VerticalStackLayout.Behaviors>

                <VerticalStackLayout Spacing="4">
                    <Label
                        Text="Settings"
                        FontFamily="OpenSansSemibold"
                        FontSize="30"
                        TextColor="{StaticResource TextPrimary}" />

                    <Label
                        Text="Personalize your training flow"
                        Style="{StaticResource SectionSubtitleStyle}" />
                </VerticalStackLayout>

                <components:HeroCard
                    Title="Make the app fit you."
                    Subtitle="Keep only the settings that actually matter for training."
                    CardBackgroundColor="{StaticResource Accent}"
                    TitleColor="{StaticResource White}"
                    SubtitleColor="#FFF3EE"
                    TopIconSource="settings.png"
                    TopIconBackgroundColor="#22FFFFFF">

                    <components:HeroCard.SecondaryActionContent>
                        <components:AppActionButton
                            Text="Import"
                            ButtonBackgroundColor="{StaticResource SurfaceSoft}"
                            ButtonStrokeColor="{StaticResource StrokeSoft}"
                            ButtonStrokeThickness="1"
                            TextColor="{StaticResource TextPrimary}"
                            ShadowOpacity="0"
                            Command="{Binding ImportDataCommand}" />
                    </components:HeroCard.SecondaryActionContent>

                    <components:HeroCard.PrimaryActionContent>
                        <components:AppActionButton
                            Text="Export"
                            ButtonBackgroundColor="{StaticResource Surface}"
                            ButtonStrokeColor="Transparent"
                            ButtonStrokeThickness="0"
                            TextColor="{StaticResource Accent}"
                            ShadowOpacity="0.10"
                            PressedScale="0.96"
                            Command="{Binding ExportDataCommand}" />
                    </components:HeroCard.PrimaryActionContent>
                </components:HeroCard>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <components:MetricTile
                        Grid.Column="0"
                        Title="Weekly Goal"
                        Value="{Binding WeeklyGoalValue}"
                        Subtitle="Training target"
                        TileBackgroundColor="{StaticResource AccentSurface}"
                        ValueColor="{StaticResource AccentText}" />

                    <components:MetricTile
                        Grid.Column="1"
                        Title="Initial Page"
                        Value="{Binding InitialPageValue}"
                        Subtitle="Opens on app start"
                        TileBackgroundColor="{StaticResource InfoSurface}"
                        ValueColor="{StaticResource TextPrimary}" />
                </Grid>

                <toolkit:Expander
                    x:Name="ProfileExpander"
                    IsExpanded="{Binding IsProfileExpanded, Mode=TwoWay}">

                    <toolkit:Expander.Header>
                        <components:SectionExpanderHeader
                            Title="Profile"
                            Subtitle="Personal details, goal, units, and initial page"
                            IconSource="edit.png"
                            HeaderBackgroundColor="{StaticResource Surface}"
                            IconBackgroundColor="{StaticResource Surface}"
                            IsExpanded="{Binding Source={x:Reference ProfileExpander}, Path=IsExpanded}" />
                    </toolkit:Expander.Header>

                    <VerticalStackLayout Padding="0,16,0,0" Spacing="16">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <components:TextField
                                Grid.Column="0"
                                Label="Age"
                                Text="{Binding Age, Mode=TwoWay}"
                                Placeholder="Enter age" />

                            <components:SingleSelectField
                                Grid.Column="1"
                                Label="Gender"
                                Placeholder="Select gender"
                                SelectedText="{Binding SelectedGender, Mode=TwoWay}"
                                IsExpanded="{Binding IsGenderExpanded, Mode=TwoWay}"
                                ItemsSource="{Binding GenderOptions}"
                                SelectItemCommand="{Binding SelectGenderCommand}"
                                DropdownBackgroundColor="{StaticResource AccentSurface}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <components:TextField
                                Grid.Column="0"
                                Label="Height"
                                Text="{Binding Height, Mode=TwoWay}"
                                Placeholder="Enter height" />

                            <components:TextField
                                Grid.Column="1"
                                Label="Weight"
                                Text="{Binding Weight, Mode=TwoWay}"
                                Placeholder="Enter weight" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <components:SingleSelectField
                                Grid.Column="0"
                                Label="Weekly goal"
                                Placeholder="Select weekly goal"
                                SelectedText="{Binding SelectedWeeklyGoal, Mode=TwoWay}"
                                IsExpanded="{Binding IsWeeklyGoalExpanded, Mode=TwoWay}"
                                ItemsSource="{Binding WeeklyGoalOptions}"
                                SelectItemCommand="{Binding SelectWeeklyGoalCommand}"
                                DropdownBackgroundColor="{StaticResource AccentSurface}" />

                            <components:TextField
                                Grid.Column="1"
                                Label="Weekly calorie target"
                                Text="{Binding WeeklyCalorieTarget, Mode=TwoWay}"
                                Placeholder="Example: 2000" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <components:SingleSelectField
                                Grid.Column="0"
                                Label="Units of measurement"
                                Placeholder="Select units"
                                SelectedText="{Binding SelectedUnits, Mode=TwoWay}"
                                IsExpanded="{Binding IsUnitsExpanded, Mode=TwoWay}"
                                ItemsSource="{Binding UnitOptions}"
                                SelectItemCommand="{Binding SelectUnitsCommand}"
                                DropdownBackgroundColor="{StaticResource AccentSurface}" />

                            <components:SingleSelectField
                                Grid.Column="1"
                                Label="Initial page"
                                Placeholder="Select initial page"
                                SelectedText="{Binding SelectedInitialPage, Mode=TwoWay}"
                                IsExpanded="{Binding IsInitialPageExpanded, Mode=TwoWay}"
                                ItemsSource="{Binding InitialPageOptions}"
                                SelectItemCommand="{Binding SelectInitialPageCommand}"
                                DropdownBackgroundColor="{StaticResource AccentSurface}" />
                        </Grid>

                        <Border
                            Style="{StaticResource SoftCardBorderStyle}"
                            BackgroundColor="{StaticResource SurfaceSoft}">
                            <Label
                                Text="Initial page is applied when the app starts."
                                Style="{StaticResource SectionSubtitleStyle}" />
                        </Border>
                    </VerticalStackLayout>
                </toolkit:Expander>

                <toolkit:Expander
                    x:Name="BehaviorExpander"
                    IsExpanded="{Binding IsBehaviorExpanded, Mode=TwoWay}">

                    <toolkit:Expander.Header>
                        <components:SectionExpanderHeader
                            Title="Behavior"
                            Subtitle="Workout screen and exercise card behavior"
                            IconSource="settings.png"
                            HeaderBackgroundColor="{StaticResource Surface}"
                            IconBackgroundColor="{StaticResource AccentSurface}"
                            IsExpanded="{Binding Source={x:Reference BehaviorExpander}, Path=IsExpanded}" />
                    </toolkit:Expander.Header>

                    <VerticalStackLayout Padding="0,16,0,0" Spacing="16">
                        <components:ToggleField
                            Style="{StaticResource SettingsToggleFieldStyle}"
                            Label="Active workout"
                            Title="Keep screen awake during workout"
                            Subtitle="Prevent the screen from sleeping while logging sets"
                            IsToggled="{Binding KeepScreenAwakeDuringWorkout, Mode=TwoWay}"
                            ToggleCommand="{Binding ToggleKeepScreenAwakeCommand}" />

                        <components:ToggleField
                            Style="{StaticResource SettingsToggleFieldStyle}"
                            Label="Workout cards"
                            Title="Auto-expand exercise cards"
                            Subtitle="Show sets by default when opening a workout"
                            IsToggled="{Binding AutoExpandExerciseCards, Mode=TwoWay}"
                            ToggleCommand="{Binding ToggleAutoExpandExerciseCardsCommand}" />
                    </VerticalStackLayout>
                </toolkit:Expander>

                <toolkit:Expander
                    x:Name="NotificationsExpander"
                    IsExpanded="{Binding IsNotificationsExpanded, Mode=TwoWay}">

                    <toolkit:Expander.Header>
                        <components:SectionExpanderHeader
                            Title="Notifications"
                            Subtitle="Only timer sound for now"
                            IconSource="history.png"
                            HeaderBackgroundColor="{StaticResource Surface}"
                            IconBackgroundColor="{StaticResource WarningSurface}"
                            IsExpanded="{Binding Source={x:Reference NotificationsExpander}, Path=IsExpanded}" />
                    </toolkit:Expander.Header>

                    <VerticalStackLayout Padding="0,16,0,0" Spacing="16">
                        <components:ToggleField
                            Style="{StaticResource SettingsToggleFieldStyle}"
                            Label="Timer"
                            Title="Rest timer sound"
                            Subtitle="Play a sound when the rest timer completes"
                            IsToggled="{Binding RestTimerSoundEnabled, Mode=TwoWay}"
                            ToggleCommand="{Binding ToggleRestTimerSoundCommand}" />
                    </VerticalStackLayout>
                </toolkit:Expander>

                <toolkit:Expander
                    x:Name="DataExpander"
                    IsExpanded="{Binding IsDataExpanded, Mode=TwoWay}">

                    <toolkit:Expander.Header>
                        <components:SectionExpanderHeader
                            Title="Data"
                            Subtitle="Import and export placeholders"
                            IconSource="statistics.png"
                            HeaderBackgroundColor="{StaticResource Surface}"
                            IconBackgroundColor="{StaticResource SuccessSurface}"
                            IsExpanded="{Binding Source={x:Reference DataExpander}, Path=IsExpanded}" />
                    </toolkit:Expander.Header>

                    <VerticalStackLayout Padding="0,16,0,0" Spacing="12">
                        <Border
                            Style="{StaticResource CardBorderStyle}"
                            BackgroundColor="{StaticResource Surface}">

                            <VerticalStackLayout Spacing="10">
                                <Label
                                    Text="These actions are placeholders for now."
                                    FontFamily="OpenSansSemibold"
                                    FontSize="15" />

                                <Label
                                    Text="Later this can hold real backup import and export flows."
                                    Style="{StaticResource SectionSubtitleStyle}" />

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <components:AppActionButton
                                        Grid.Column="0"
                                        Text="Import data"
                                        ButtonBackgroundColor="{StaticResource SurfaceSoft}"
                                        ButtonStrokeColor="{StaticResource StrokeSoft}"
                                        ButtonStrokeThickness="1"
                                        TextColor="{StaticResource TextPrimary}"
                                        ShadowOpacity="0"
                                        Command="{Binding ImportDataCommand}" />

                                    <components:AppActionButton
                                        Grid.Column="1"
                                        Text="Export data"
                                        ButtonBackgroundColor="{StaticResource Accent}"
                                        ButtonStrokeColor="Transparent"
                                        ButtonStrokeThickness="0"
                                        TextColor="{StaticResource White}"
                                        ShadowOpacity="0.10"
                                        Command="{Binding ExportDataCommand}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </toolkit:Expander>
            </VerticalStackLayout>
        </ScrollView>

        <Grid
            VerticalOptions="End"
            HorizontalOptions="Fill"
            Margin="20,0,20,18"
            InputTransparent="False">

            <components:BottomNavBarSimple
                LeftPrimaryItem="{Binding DashboardNavItem}"
                LeftSecondaryItem="{Binding WorkoutsNavItem}"
                RightPrimaryItem="{Binding CalendarNavItem}"
                RightSecondaryItem="{Binding SettingsNavItem}"
                ItemCommand="{Binding SelectNavCommand}"
                BarBackgroundColor="{StaticResource Surface}"
                BarStrokeColor="{StaticResource StrokeSoft}"
                BarShadowBrush="#18000000" />
        </Grid>
        
        <components:AppDialog
            ZIndex="30"
            IsOpen="{Binding IsInfoDialogVisible}"
            Title="{Binding InfoDialogTitle}"
            Message="{Binding InfoDialogMessage}"
            IconSource="{Binding InfoDialogIconSource}"
            IconBackgroundColor="{StaticResource AccentSurface}"
            PrimaryButtonText="OK"
            ShowSecondaryButton="False"
            PrimaryCommand="{Binding CloseInfoDialogCommand}"
            DismissCommand="{Binding CloseInfoDialogCommand}" />

        <components:AppDialog
            ZIndex="30"
            IsOpen="{Binding IsDataDialogVisible}"
            Title="{Binding DataDialogTitle}"
            Message="{Binding DataDialogMessage}"
            IconSource="save.png"
            IconBackgroundColor="{StaticResource AccentSurface}"
            PrimaryButtonText="OK"
            ShowSecondaryButton="False"
            PrimaryCommand="{Binding CloseDataDialogCommand}"
            DismissCommand="{Binding CloseDataDialogCommand}" />
    </Grid>

</ContentPage>