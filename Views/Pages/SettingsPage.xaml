<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XerSize.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:XerSize.ViewModels.Settings"
    x:DataType="viewModels:SettingsPageViewModel"
    Shell.NavBarIsVisible="False"
    Title="Settings">

    <ScrollView>
        <Grid
            Style="{StaticResource PageRootGridStyle}"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto"
            RowSpacing="14">

            <VerticalStackLayout
                Grid.Row="0"
                Spacing="4">
                <Label
                    Text="Settings"
                    Style="{StaticResource PageTitleLabelStyle}" />
                <Label
                    Text="Appearance, profile, units, and sync preferences."
                    Style="{StaticResource MutedLabelStyle}" />
            </VerticalStackLayout>

            <Border
                Grid.Row="1"
                Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="2">
                        <Label
                            Text="Theme"
                            Style="{StaticResource BodyLabelStyle}" />
                        <Label
                            Text="{Binding ThemeSummary}"
                            Style="{StaticResource MutedLabelStyle}" />
                    </VerticalStackLayout>

                    <Border
                        Padding="4"
                        BackgroundColor="{DynamicResource SurfaceMutedColor}"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                            <Button
                                Text="Light"
                                Padding="14,10"
                                Command="{Binding ApplyLightThemeCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{DynamicResource PrimaryTextColor}">
                                <Button.Triggers>
                                    <DataTrigger
                                        TargetType="Button"
                                        Binding="{Binding IsLightTheme}"
                                        Value="True">
                                        <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
                                        <Setter Property="TextColor" Value="{DynamicResource OnPrimaryColor}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>

                            <Button
                                Grid.Column="1"
                                Text="Dark"
                                Padding="14,10"
                                Command="{Binding ApplyDarkThemeCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{DynamicResource PrimaryTextColor}">
                                <Button.Triggers>
                                    <DataTrigger
                                        TargetType="Button"
                                        Binding="{Binding IsDarkTheme}"
                                        Value="True">
                                        <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
                                        <Setter Property="TextColor" Value="{DynamicResource OnPrimaryColor}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border
                Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="2">
                        <Label
                            Text="User Profile"
                            Style="{StaticResource BodyLabelStyle}" />
                        <Label
                            Text="{Binding UserProfileSummary}"
                            Style="{StaticResource MutedLabelStyle}" />
                    </VerticalStackLayout>

                    <Grid
                        ColumnDefinitions="*,*"
                        ColumnSpacing="12"
                        RowDefinitions="Auto,Auto,Auto"
                        RowSpacing="12">

                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                            <Label
                                Text="Weight"
                                Style="{StaticResource MutedLabelStyle}" />
                            <Entry
                                Text="{Binding BodyWeightText}"
                                Keyboard="Numeric"
                                Placeholder="e.g. 80" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                            <Label
                                Text="Height"
                                Style="{StaticResource MutedLabelStyle}" />
                            <Entry
                                Text="{Binding HeightText}"
                                Keyboard="Numeric"
                                Placeholder="e.g. 180" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
                            <Label
                                Text="Age"
                                Style="{StaticResource MutedLabelStyle}" />
                            <Entry
                                Text="{Binding AgeText}"
                                Keyboard="Numeric"
                                Placeholder="e.g. 25" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                            <Label
                                Text="Sex"
                                Style="{StaticResource MutedLabelStyle}" />
                            <Border
                                Padding="4"
                                BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Button
                                        Text="Male"
                                        Padding="14,10"
                                        Command="{Binding SelectMaleCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{DynamicResource PrimaryTextColor}">
                                        <Button.Triggers>
                                            <DataTrigger
                                                TargetType="Button"
                                                Binding="{Binding IsMaleSelected}"
                                                Value="True">
                                                <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
                                                <Setter Property="TextColor" Value="{DynamicResource OnPrimaryColor}" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <Button
                                        Grid.Column="1"
                                        Text="Female"
                                        Padding="14,10"
                                        Command="{Binding SelectFemaleCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{DynamicResource PrimaryTextColor}">
                                        <Button.Triggers>
                                            <DataTrigger
                                                TargetType="Button"
                                                Binding="{Binding IsFemaleSelected}"
                                                Value="True">
                                                <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
                                                <Setter Property="TextColor" Value="{DynamicResource OnPrimaryColor}" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <Border
                            Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Padding="12"
                            BackgroundColor="{DynamicResource SurfaceMutedColor}"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>

                            <Label
                                Text="{Binding UserProfileHint}"
                                Style="{StaticResource MutedLabelStyle}" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border
                Grid.Row="3"
                Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="2">
                        <Label
                            Text="Units &amp; Measurements"
                            Style="{StaticResource BodyLabelStyle}" />
                        <Label
                            Text="{Binding UnitsSummary}"
                            Style="{StaticResource MutedLabelStyle}" />
                    </VerticalStackLayout>

                    <Grid
                        ColumnDefinitions="*,*"
                        ColumnSpacing="12"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="12">

                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                            <Label
                                Text="Weight Unit"
                                Style="{StaticResource MutedLabelStyle}" />
                            <Border
                                Padding="4"
                                BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Button
                                        Text="kg"
                                        Padding="14,10"
                                        Command="{Binding SelectKgCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{DynamicResource PrimaryTextColor}">
                                        <Button.Triggers>
                                            <DataTrigger
                                                TargetType="Button"
                                                Binding="{Binding IsKgSelected}"
                                                Value="True">
                                                <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
                                                <Setter Property="TextColor" Value="{DynamicResource OnPrimaryColor}" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <Button
                                        Grid.Column="1"
                                        Text="lbs"
                                        Padding="14,10"
                                        Command="{Binding SelectLbsCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{DynamicResource PrimaryTextColor}">
                                        <Button.Triggers>
                                            <DataTrigger
                                                TargetType="Button"
                                                Binding="{Binding IsLbsSelected}"
                                                Value="True">
                                                <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
                                                <Setter Property="TextColor" Value="{DynamicResource OnPrimaryColor}" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                            <Label
                                Text="System"
                                Style="{StaticResource MutedLabelStyle}" />
                            <Border
                                Padding="4"
                                BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Button
                                        Text="Metric"
                                        Padding="14,10"
                                        Command="{Binding SelectMetricCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{DynamicResource PrimaryTextColor}">
                                        <Button.Triggers>
                                            <DataTrigger
                                                TargetType="Button"
                                                Binding="{Binding IsMetricSelected}"
                                                Value="True">
                                                <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
                                                <Setter Property="TextColor" Value="{DynamicResource OnPrimaryColor}" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <Button
                                        Grid.Column="1"
                                        Text="Imperial"
                                        Padding="14,10"
                                        Command="{Binding SelectImperialCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{DynamicResource PrimaryTextColor}">
                                        <Button.Triggers>
                                            <DataTrigger
                                                TargetType="Button"
                                                Binding="{Binding IsImperialSelected}"
                                                Value="True">
                                                <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
                                                <Setter Property="TextColor" Value="{DynamicResource OnPrimaryColor}" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <Border
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Padding="12"
                            BackgroundColor="{DynamicResource SurfaceMutedColor}"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>

                            <Label
                                Text="These settings control how values are displayed across the app."
                                Style="{StaticResource MutedLabelStyle}" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border
                Grid.Row="4"
                Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label
                                Text="Cloud Sync"
                                Style="{StaticResource BodyLabelStyle}" />
                            <Label
                                Text="{Binding CloudSyncSummary}"
                                Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>

                        <Switch
                            Grid.Column="1"
                            IsToggled="{Binding IsCloudSyncEnabled}"
                            VerticalOptions="Center" />
                    </Grid>

                    <Border
                        Padding="12"
                        BackgroundColor="{DynamicResource SurfaceMutedColor}"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>

                        <Label
                            Text="This currently saves the preference locally only. Actual account sync / backup flow still needs backend implementation."
                            Style="{StaticResource MutedLabelStyle}" />
                    </Border>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>