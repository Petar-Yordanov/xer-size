<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XerSize.Views.Pages.HistorySessionDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:XerSize.ViewModels.History"
    xmlns:models="clr-namespace:XerSize.Models"
    x:DataType="viewModels:HistorySessionDetailsPageViewModel"
    Title="Session Details">

	<ScrollView>
		<Grid Style="{StaticResource PageRootGridStyle}" RowDefinitions="Auto,Auto,*">
			<Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
				<VerticalStackLayout Spacing="8">
					<Label Text="{Binding Session.RoutineName}" Style="{StaticResource PageTitleLabelStyle}" />
					<Label Text="{Binding Session.WorkoutName}" Style="{StaticResource BodyLabelStyle}" />
					<Label Text="{Binding Session.PerformedAt, StringFormat='{}{0:ddd, dd MMM yyyy • HH:mm}'}" Style="{StaticResource MutedLabelStyle}" />
					<Label Text="{Binding Session.DurationMinutes, StringFormat='Duration: {0} min'}" Style="{StaticResource MutedLabelStyle}" />
					<Label Text="{Binding Session.EstimatedCaloriesBurned, StringFormat='Calories: {0:F0} kcal'}" Style="{StaticResource MutedLabelStyle}" />
					<Label Text="{Binding Session.BodyWeightKg, StringFormat='Bodyweight: {0:F1} kg'}" Style="{StaticResource MutedLabelStyle}" />
				</VerticalStackLayout>
			</Border>

			<Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="10">
				<Border Style="{StaticResource CardBorderStyle}">
					<VerticalStackLayout>
						<Label Text="Volume" Style="{StaticResource MutedLabelStyle}" />
						<Label Text="{Binding Session.TotalVolume, StringFormat='{}{0:F0} kg'}" Style="{StaticResource BodyLabelStyle}" />
					</VerticalStackLayout>
				</Border>

				<Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
					<VerticalStackLayout>
						<Label Text="Sets" Style="{StaticResource MutedLabelStyle}" />
						<Label Text="{Binding Session.TotalSets}" Style="{StaticResource BodyLabelStyle}" />
					</VerticalStackLayout>
				</Border>

				<Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
					<VerticalStackLayout>
						<Label Text="Reps" Style="{StaticResource MutedLabelStyle}" />
						<Label Text="{Binding Session.TotalReps}" Style="{StaticResource BodyLabelStyle}" />
					</VerticalStackLayout>
				</Border>
			</Grid>

			<CollectionView
                Grid.Row="2"
                Margin="0,12,0,0"
                ItemsSource="{Binding Session.Exercises}"
                SelectionMode="None">
				<CollectionView.ItemTemplate>
					<DataTemplate x:DataType="models:HistoryDetailExerciseRow">
						<Border Margin="0,0,0,12" Style="{StaticResource CardBorderStyle}">
							<VerticalStackLayout Spacing="6">
								<Label Text="{Binding Name}" Style="{StaticResource BodyLabelStyle}" />
								<Label Text="{Binding MetaText}" Style="{StaticResource MutedLabelStyle}" />
								<Label Text="{Binding VolumeText}" Style="{StaticResource MutedLabelStyle}" />

								<CollectionView ItemsSource="{Binding Sets}" SelectionMode="None">
									<CollectionView.ItemTemplate>
										<DataTemplate x:DataType="models:HistoryDetailSetRow">
											<Label
                                                Margin="8,0,0,0"
                                                Text="{Binding Text}"
                                                Style="{StaticResource MutedLabelStyle}" />
										</DataTemplate>
									</CollectionView.ItemTemplate>
								</CollectionView>
							</VerticalStackLayout>
						</Border>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>
		</Grid>
	</ScrollView>
</ContentPage>