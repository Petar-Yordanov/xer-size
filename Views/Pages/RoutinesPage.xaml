<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XerSize.Views.Pages.RoutinesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:components="clr-namespace:XerSize.Views.Components"
    xmlns:viewModels="clr-namespace:XerSize.ViewModels.Routines"
    xmlns:models="clr-namespace:XerSize.Models"
    x:DataType="viewModels:RoutinesPageViewModel"
    x:Name="PageRoot"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    Title="Routines">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0">
            <Grid
                Style="{StaticResource PageRootGridStyle}"
                RowDefinitions="Auto,Auto,Auto,*"
                RowSpacing="8">

                <components:RoutineDropdown
                    Grid.Row="1"
                    SelectedText="{Binding SelectedRoutineName}"
                    TapCommand="{Binding ToggleRoutineSheetCommand}"
                    AddCommand="{Binding AddRoutineCommand}"
                    LongPressCommand="{Binding HandleRoutineLongPressCommand}"
                    IsLongPressEnabled="True"
                    ShowAddButton="True"
                    AddButtonText="+"
                    TrailingIconText="v" />

                <components:WorkoutTabsBar
                    Grid.Row="2"
                    ItemsSource="{Binding VisibleWorkouts}"
                    SelectedItem="{Binding SelectedWorkout}"
                    AddCommand="{Binding AddWorkoutCommand}"
                    LongPressCommand="{Binding HandleWorkoutLongPressCommand}" />

                <Grid Grid.Row="3" Margin="0,2,0,0">
                    <components:Card>
                        <Grid Padding="0">
                            <CollectionView
                                Margin="0,0,0,72"
                                ItemsSource="{Binding VisibleExercises}"
                                SelectionMode="None"
                                VerticalOptions="Fill"
                                ItemSizingStrategy="MeasureAllItems"
                                EmptyView="No exercises in this workout yet.">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:WorkoutExerciseCardRow">
                                        <Border
                                            Margin="0,0,0,12"
                                            Padding="12"
                                            BackgroundColor="{DynamicResource SurfaceColor}"
                                            Stroke="{DynamicResource BorderColor}"
                                            StrokeThickness="1">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="16" />
                                            </Border.StrokeShape>

                                            <VerticalStackLayout Spacing="10">
                                                <Grid
                                                    ColumnDefinitions="64,*,Auto"
                                                    RowDefinitions="Auto,Auto"
                                                    ColumnSpacing="10"
                                                    RowSpacing="6">

                                                    <Grid
                                                        Grid.RowSpan="2"
                                                        Grid.Column="0">
                                                        <Grid.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding EditCommand}" />
                                                        </Grid.GestureRecognizers>

                                                        <components:ImageTile
                                                            ImageSource="{Binding PreviewImageSource}"
                                                            PlaceholderTitle=""
                                                            PlaceholderSubtitle=""
                                                            ActionText=""
                                                            TileHeight="64"
                                                            TileWidth="64" />
                                                    </Grid>

                                                    <VerticalStackLayout
                                                        Grid.Column="1"
                                                        Grid.Row="0"
                                                        Grid.RowSpan="2"
                                                        Spacing="2">
                                                        <VerticalStackLayout.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding EditCommand}" />
                                                        </VerticalStackLayout.GestureRecognizers>

                                                        <Label
                                                            Text="{Binding Name}"
                                                            LineBreakMode="TailTruncation"
                                                            Style="{StaticResource BodyLabelStyle}" />

                                                        <Label
                                                            Text="{Binding PrimaryMusclesText}"
                                                            LineBreakMode="TailTruncation"
                                                            MaxLines="1"
                                                            Style="{StaticResource MutedLabelStyle}" />
                                                    </VerticalStackLayout>

                                                    <components:Button
                                                        Grid.Column="2"
                                                        Grid.Row="0"
                                                        ImageSource="delete.png"
                                                        ButtonStyle="{StaticResource SecondaryButtonStyle}"
                                                        Command="{Binding DeleteCommand}" />
                                                </Grid>

                                                <toolkit:Expander
                                                    IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                                    <toolkit:Expander.Header>
                                                        <Border
                                                            Padding="12"
                                                            BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                                            Stroke="{DynamicResource BorderColor}"
                                                            StrokeThickness="1">
                                                            <Border.StrokeShape>
                                                                <RoundRectangle CornerRadius="14" />
                                                            </Border.StrokeShape>

                                                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                                                                <Label
                                                                    Text="{Binding ExpandButtonText}"
                                                                    VerticalOptions="Center"
                                                                    Style="{StaticResource BodyLabelStyle}" />

                                                                <Image
                                                                    WidthRequest="16"
                                                                    HeightRequest="16"
                                                                    Aspect="AspectFit"
                                                                    VerticalOptions="Center">
                                                                    <Image.Triggers>
                                                                        <DataTrigger TargetType="Image" Binding="{Binding IsExpanded}" Value="True">
                                                                            <Setter Property="Source" Value="expand_less.png" />
                                                                        </DataTrigger>
                                                                        <DataTrigger TargetType="Image" Binding="{Binding IsExpanded}" Value="False">
                                                                            <Setter Property="Source" Value="expand_more.png" />
                                                                        </DataTrigger>
                                                                    </Image.Triggers>
                                                                </Image>
                                                            </HorizontalStackLayout>
                                                        </Border>
                                                    </toolkit:Expander.Header>

                                                    <Border
                                                        Margin="0,8,0,0"
                                                        Padding="12"
                                                        BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                                        StrokeThickness="0">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="14" />
                                                        </Border.StrokeShape>

                                                        <VerticalStackLayout Spacing="8">
                                                            <Label
                                                                Text="Sets"
                                                                Style="{StaticResource BodyLabelStyle}" />

                                                            <VerticalStackLayout
                                                                Spacing="6"
                                                                BindableLayout.ItemsSource="{Binding GroupedSets}">
                                                                <BindableLayout.ItemTemplate>
                                                                    <DataTemplate x:DataType="viewModels:WorkoutExerciseGroupedSetRow">
                                                                        <FlexLayout
                                                                            Wrap="Wrap"
                                                                            Direction="Row"
                                                                            JustifyContent="Center"
                                                                            AlignItems="Center"
                                                                            BindableLayout.ItemsSource="{Binding Parts}">
                                                                            <BindableLayout.ItemTemplate>
                                                                                <DataTemplate x:DataType="models:SetPartItem">
                                                                                    <HorizontalStackLayout
                                                                                        Margin="0,0,3,3"
                                                                                        Spacing="3"
                                                                                        VerticalOptions="Center">
                                                                                        <Label
                                                                                            Text="×"
                                                                                            VerticalOptions="Center"
                                                                                            IsVisible="{Binding ShowSeparator}"
                                                                                            Style="{StaticResource MutedLabelStyle}" />
                                                                                        <Border
                                                                                            Padding="7,2"
                                                                                            BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                                                                            Stroke="{DynamicResource BorderColor}"
                                                                                            StrokeThickness="1"
                                                                                            VerticalOptions="Center">
                                                                                            <Border.StrokeShape>
                                                                                                <RoundRectangle CornerRadius="10" />
                                                                                            </Border.StrokeShape>
                                                                                            <Label
                                                                                                Text="{Binding Text}"
                                                                                                LineBreakMode="TailTruncation"
                                                                                                MaxLines="1"
                                                                                                Style="{StaticResource MutedLabelStyle}" />
                                                                                        </Border>
                                                                                    </HorizontalStackLayout>
                                                                                </DataTemplate>
                                                                            </BindableLayout.ItemTemplate>
                                                                        </FlexLayout>
                                                                    </DataTemplate>
                                                                </BindableLayout.ItemTemplate>
                                                            </VerticalStackLayout>
                                                        </VerticalStackLayout>
                                                    </Border>
                                                </toolkit:Expander>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Grid>
                    </components:Card>

                    <Button
                        Margin="12,0,12,12"
                        VerticalOptions="End"
                        HorizontalOptions="Fill"
                        ZIndex="20"
                        Text="Workout actions"
                        Command="{Binding ToggleQuickActionsCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinimumHeightRequest="44"
                        Padding="14,10" />
                </Grid>
            </Grid>

            <Grid
                IsVisible="{Binding IsRoutineSheetOpen}"
                InputTransparent="False"
                ZIndex="30">
                <BoxView BackgroundColor="#66000000">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseRoutineSheetCommand}" />
                    </BoxView.GestureRecognizers>
                </BoxView>

                <Border
                    VerticalOptions="End"
                    Margin="12,0,12,12"
                    Padding="0,12,0,18"
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="10">
                        <BoxView
                            HeightRequest="5"
                            WidthRequest="48"
                            HorizontalOptions="Center"
                            Color="{DynamicResource BorderColor}" />

                        <Label
                            Margin="18,0,18,0"
                            Text="Select Routine"
                            Style="{StaticResource BodyLabelStyle}" />

                        <CollectionView
                            ItemsSource="{Binding Routines}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem"
                            MaximumHeightRequest="320">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <Border
                                        Margin="12,0,12,8"
                                        Padding="14,12"
                                        BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                        StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16" />
                                        </Border.StrokeShape>

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectRoutineCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label
                                                Text="{Binding Name}"
                                                VerticalOptions="Center"
                                                Style="{StaticResource BodyLabelStyle}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid
                IsVisible="{Binding IsQuickActionsOpen}"
                InputTransparent="False"
                ZIndex="40">
                <BoxView BackgroundColor="#66000000">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseQuickActionsCommand}" />
                    </BoxView.GestureRecognizers>
                </BoxView>

                <Border
                    VerticalOptions="End"
                    Margin="12,0,12,12"
                    Padding="0,12,0,18"
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="10">
                        <BoxView
                            HeightRequest="5"
                            WidthRequest="48"
                            HorizontalOptions="Center"
                            Color="{DynamicResource BorderColor}" />

                        <Label
                            Margin="18,0,18,0"
                            Text="Workout actions"
                            Style="{StaticResource BodyLabelStyle}" />

                        <VerticalStackLayout Spacing="8" Margin="12,0,12,0">
                            <Button
                                Text="+ Exercise"
                                Command="{Binding AddExerciseCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinimumHeightRequest="44"
                                Padding="14,10" />

                            <Button
                                Text="Start Workout"
                                Command="{Binding StartWorkoutCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinimumHeightRequest="44"
                                Padding="14,10" />

                            <Button
                                Text="Workout Statistics"
                                Command="{Binding OpenWorkoutStatisticsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinimumHeightRequest="44"
                                Padding="14,10" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>

        <components:BottomNavBar Grid.Row="1">
            <HorizontalStackLayout Spacing="4">
                <components:BottomNavBarItem Text="Routines" Icon="routines.png" Route="routines" IsSelected="True" />
                <components:BottomNavBarItem Text="Exercises" Icon="exercises.png" Route="exercises" />
                <components:BottomNavBarItem Text="History" Icon="history.png" Route="history" />
                <components:BottomNavBarItem Text="Stats" Icon="statistics.png" Route="statistics" />
                <components:BottomNavBarItem Text="Settings" Icon="settings.png" Route="settingsTab" />
            </HorizontalStackLayout>
        </components:BottomNavBar>
    </Grid>
</ContentPage>