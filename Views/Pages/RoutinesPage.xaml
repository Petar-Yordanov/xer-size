<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XerSize.Views.Pages.RoutinesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:XerSize.Views.Components"
    xmlns:viewModels="clr-namespace:XerSize.ViewModels.Routines"
    xmlns:models="clr-namespace:XerSize.Models"
    x:DataType="viewModels:RoutinesPageViewModel"
    x:Name="PageRoot"
    Title="Routines">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Text="Settings"
            Command="{Binding OpenSettingsCommand}" />
    </ContentPage.ToolbarItems>

    <Grid>
        <Grid
            Style="{StaticResource PageRootGridStyle}"
            RowDefinitions="Auto,Auto,Auto,*"
            RowSpacing="8">

            <components:RoutineDropdown
                Grid.Row="1"
                SelectedText="{Binding SelectedRoutineName}"
                TapCommand="{Binding ToggleRoutineSheetCommand}"
                AddCommand="{Binding AddRoutineCommand}"
                LongPressCommand="{Binding HandleRoutineLongPressCommand}"
                IsLongPressEnabled="True"
                ShowAddButton="True"
                AddButtonText="+"
                TrailingIconText="v" />

            <components:WorkoutTabsBar
                Grid.Row="2"
                ItemsSource="{Binding VisibleWorkouts}"
                SelectedItem="{Binding SelectedWorkout}"
                AddCommand="{Binding AddWorkoutCommand}"
                LongPressCommand="{Binding HandleWorkoutLongPressCommand}" />

            <Grid Grid.Row="3" Margin="0,2,0,0">

                <Border
                    Padding="12,12,12,48"
                    Style="{StaticResource CardBorderStyle}">
                    <CollectionView
                        ItemsSource="{Binding VisibleExercises}"
                        SelectionMode="None"
                        VerticalOptions="FillAndExpand"
                        EmptyView="No exercises in this workout yet.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:WorkoutExerciseCardRow">
                                <Border
                                    x:DataType="{x:Null}"
                                    Margin="0,0,0,12"
                                    Padding="12"
                                    BackgroundColor="{DynamicResource SurfaceColor}"
                                    Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.EditExerciseCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <VerticalStackLayout Spacing="10">
                                        <Grid
                                            ColumnDefinitions="64,*,Auto"
                                            RowDefinitions="Auto,Auto"
                                            ColumnSpacing="10"
                                            RowSpacing="6">

                                            <Border
                                                Grid.RowSpan="2"
                                                Grid.Column="0"
                                                HeightRequest="64"
                                                WidthRequest="64"
                                                Padding="0"
                                                BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                                Stroke="{DynamicResource BorderColor}"
                                                StrokeThickness="1">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="14" />
                                                </Border.StrokeShape>

                                                <Grid>
                                                    <Image
                                                        IsVisible="{Binding HasImage}"
                                                        Source="{Binding PreviewImageSource}"
                                                        Aspect="AspectFill" />

                                                    <Label
                                                        Text="{Binding PlaceholderText}"
                                                        IsVisible="{Binding HasImage, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="Center"
                                                        Style="{StaticResource BodyLabelStyle}" />
                                                </Grid>
                                            </Border>

                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                Grid.Row="0"
                                                Grid.RowSpan="2"
                                                Spacing="2">
                                                <Label
                                                    Text="{Binding Name}"
                                                    LineBreakMode="TailTruncation"
                                                    Style="{StaticResource BodyLabelStyle}" />

                                                <Label
                                                    Text="{Binding PrimaryMusclesText}"
                                                    LineBreakMode="TailTruncation"
                                                    MaxLines="1"
                                                    Style="{StaticResource MutedLabelStyle}" />

                                                <Label
                                                    Text="{Binding RestText}"
                                                    LineBreakMode="TailTruncation"
                                                    MaxLines="1"
                                                    Style="{StaticResource MutedLabelStyle}" />
                                            </VerticalStackLayout>

                                            <Button
                                                Grid.Column="2"
                                                Grid.Row="0"
                                                Padding="10,6"
                                                Text="Delete"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.DeleteExerciseCommand}"
                                                CommandParameter="{Binding .}" />

                                            <Button
                                                Grid.Column="2"
                                                Grid.Row="1"
                                                Padding="10,6"
                                                Text="{Binding ExpandButtonText}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.ToggleExerciseExpandedCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid>

                                        <Border
                                            IsVisible="{Binding IsExpanded}"
                                            Padding="12"
                                            BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                            StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>

                                            <VerticalStackLayout Spacing="8">
                                                <Label
                                                    Text="Sets"
                                                    Style="{StaticResource BodyLabelStyle}" />

                                                <CollectionView
                                                    ItemsSource="{Binding GroupedSets}"
                                                    SelectionMode="None">
                                                    <CollectionView.ItemTemplate>
                                                        <DataTemplate x:DataType="viewModels:WorkoutExerciseGroupedSetRow">
                                                            <Label
                                                                Margin="0,0,0,2"
                                                                Text="{Binding SummaryText}"
                                                                Style="{StaticResource MutedLabelStyle}" />
                                                        </DataTemplate>
                                                    </CollectionView.ItemTemplate>
                                                </CollectionView>
                                            </VerticalStackLayout>
                                        </Border>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <Border
                    Margin="12,0,12,12"
                    HeightRequest="38"
                    VerticalOptions="End"
                    HorizontalOptions="Fill"
                    BackgroundColor="{DynamicResource PrimaryColor}"
                    StrokeThickness="0"
                    ZIndex="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleQuickActionsCommand}" />
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,0">
                        <Label
                            Grid.Column="0"
                            Text="+"
                            FontSize="18"
                            VerticalOptions="Center"
                            TextColor="{DynamicResource OnPrimaryColor}" />

                        <Label
                            Grid.Column="1"
                            Text="Workout actions"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            TextColor="{DynamicResource OnPrimaryColor}"
                            FontFamily="OpenSansSemibold"
                            FontSize="13" />

                        <Label
                            Grid.Column="2"
                            Text="⋯"
                            FontSize="18"
                            VerticalOptions="Center"
                            TextColor="{DynamicResource OnPrimaryColor}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid
            x:DataType="{x:Null}"
            IsVisible="{Binding IsRoutineSheetOpen}"
            InputTransparent="False"
            ZIndex="40">

            <BoxView BackgroundColor="#66000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseRoutineSheetCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border
                VerticalOptions="End"
                Margin="12,0,12,12"
                Padding="0,12,0,18"
                BackgroundColor="{DynamicResource SurfaceColor}"
                Stroke="{DynamicResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <BoxView
                        HeightRequest="5"
                        WidthRequest="48"
                        HorizontalOptions="Center"
                        Color="{DynamicResource BorderColor}" />

                    <Label
                        Margin="18,0,18,0"
                        Text="Select Routine"
                        Style="{StaticResource BodyLabelStyle}" />

                    <CollectionView
                        ItemsSource="{Binding Routines}"
                        SelectionMode="None"
                        MaximumHeightRequest="320">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Routine">
                                <Border
                                    x:DataType="{x:Null}"
                                    Margin="12,0,12,8"
                                    Padding="14,12"
                                    BackgroundColor="{DynamicResource SurfaceMutedColor}"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectRoutineCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label
                                            Text="{Binding Name}"
                                            VerticalOptions="Center"
                                            Style="{StaticResource BodyLabelStyle}" />

                                        <Label
                                            Grid.Column="1"
                                            Text=">"
                                            VerticalOptions="Center"
                                            Style="{StaticResource MutedLabelStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid
            x:DataType="{x:Null}"
            IsVisible="{Binding IsQuickActionsOpen}"
            InputTransparent="False"
            ZIndex="50">
            <BoxView BackgroundColor="#22000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseQuickActionsCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>
        </Grid>

        <Grid
            x:DataType="{x:Null}"
            IsVisible="{Binding IsQuickActionsOpen}"
            InputTransparent="False"
            ZIndex="60"
            Padding="28,0,28,96">

            <VerticalStackLayout
                VerticalOptions="End"
                HorizontalOptions="End"
                Spacing="10">

                <Border
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="1"
                    Padding="16,12"
                    MinimumWidthRequest="220">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AddExerciseCommand}" />
                    </Border.GestureRecognizers>

                    <HorizontalStackLayout Spacing="12">
                        <Label
                            Text="+"
                            FontSize="18"
                            VerticalOptions="Center"
                            TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label
                            Text="Add Exercise"
                            VerticalOptions="Center"
                            Style="{StaticResource BodyLabelStyle}" />
                    </HorizontalStackLayout>
                </Border>

                <Border
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="1"
                    Padding="16,12"
                    MinimumWidthRequest="220">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding StartWorkoutCommand}" />
                    </Border.GestureRecognizers>

                    <HorizontalStackLayout Spacing="12">
                        <Label
                            Text=">"
                            FontSize="16"
                            VerticalOptions="Center"
                            TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label
                            Text="Start Workout"
                            VerticalOptions="Center"
                            Style="{StaticResource BodyLabelStyle}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>