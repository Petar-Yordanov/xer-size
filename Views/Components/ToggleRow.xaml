<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.ToggleRow"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:ToggleRow">

	<Border Style="{StaticResource CardBorderStyle}">
		<Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
			<VerticalStackLayout Spacing="2">
				<Label
                    Text="{Binding Source={x:Reference This}, Path=Title}"
                    Style="{StaticResource SectionTitleLabelStyle}" />
				<Label
                    Text="{Binding Source={x:Reference This}, Path=Subtitle}"
                    Style="{StaticResource MutedLabelStyle}" />
			</VerticalStackLayout>

			<Switch
                Grid.Column="1"
                IsToggled="{Binding Source={x:Reference This}, Path=IsToggled, Mode=TwoWay}"
                Style="{StaticResource AppSwitchStyle}"
                VerticalOptions="Center" />
		</Grid>
	</Border>
</ContentView>