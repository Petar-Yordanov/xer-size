<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.Button"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="This">

    <Border
        x:Name="ButtonSurface"
        StrokeThickness="1"
        Padding="14,10"
        MinimumHeightRequest="42"
        BackgroundColor="{DynamicResource PrimaryColor}"
        Stroke="{DynamicResource PrimaryColor}"
        HorizontalOptions="Fill"
        VerticalOptions="Center">
        <Border.StrokeShape>
            <RoundRectangle x:Name="ButtonShape" CornerRadius="14" />
        </Border.StrokeShape>

        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTapped" />
        </Border.GestureRecognizers>

        <Grid
            x:Name="ButtonContentGrid"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="8">
            <Image
                x:Name="ButtonIcon"
                Grid.Column="0"
                IsVisible="False"
                WidthRequest="18"
                HeightRequest="18"
                Aspect="AspectFit"
                VerticalOptions="Center"
                HorizontalOptions="Center" />

            <Label
                x:Name="ButtonLabel"
                Grid.Column="1"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                HorizontalTextAlignment="Center"
                VerticalTextAlignment="Center"
                LineBreakMode="TailTruncation"
                MaxLines="1"
                FontFamily="OpenSansSemibold"
                FontSize="13"
                TextColor="{DynamicResource OnPrimaryColor}" />
        </Grid>
    </Border>
</ContentView>
