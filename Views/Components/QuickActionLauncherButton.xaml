<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.QuickActionLauncherButton"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:QuickActionLauncherButton">

    <Border
        HeightRequest="44"
        Padding="14,0"
        BackgroundColor="{DynamicResource PrimaryColor}"
        StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16" />
        </Border.StrokeShape>

        <Border.GestureRecognizers>
            <TapGestureRecognizer
                Command="{Binding Source={x:Reference This}, Path=Command}"
                CommandParameter="{Binding Source={x:Reference This}, Path=CommandParameter}" />
        </Border.GestureRecognizers>

        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
            <Label
                Text="{Binding Source={x:Reference This}, Path=LeadingIconText}"
                VerticalOptions="Center"
                InputTransparent="True"
                TextColor="{DynamicResource OnPrimaryColor}"
                FontSize="15" />

            <Label
                Grid.Column="1"
                Text="{Binding Source={x:Reference This}, Path=Text}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                InputTransparent="True"
                TextColor="{DynamicResource OnPrimaryColor}"
                FontFamily="OpenSansSemibold"
                FontSize="13"
                LineBreakMode="TailTruncation"
                MaxLines="1" />
        </Grid>
    </Border>
</ContentView>