<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.IconButton"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:IconButton">

	<Button
        Text="{Binding Source={x:Reference This}, Path=Text}"
        Command="{Binding Source={x:Reference This}, Path=Command}"
        CommandParameter="{Binding Source={x:Reference This}, Path=CommandParameter}"
        Style="{StaticResource IconButtonStyle}" />
</ContentView>