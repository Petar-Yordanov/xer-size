<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.SheetOptionRow"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:SheetOptionRow">

    <Grid>
        <Border
            Margin="12,0,12,6"
            Padding="12,10"
            BackgroundColor="{DynamicResource SurfaceColor}"
            Stroke="{DynamicResource BorderColor}"
            StrokeThickness="1"
            MinimumHeightRequest="44">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>

            <Border.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding Source={x:Reference This}, Path=TapCommand}"
                    CommandParameter="{Binding Source={x:Reference This}, Path=TapCommandParameter}" />
            </Border.GestureRecognizers>

            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Label
                    Text="•"
                    VerticalOptions="Center"
                    TextColor="{DynamicResource SecondaryTextColor}"
                    FontSize="12" />

                <Label
                    Grid.Column="1"
                    Text="{Binding Source={x:Reference This}, Path=Text}"
                    VerticalOptions="Center"
                    LineBreakMode="TailTruncation"
                    Style="{StaticResource BodyLabelStyle}" />

                <Label
                    Grid.Column="2"
                    Text="✓"
                    IsVisible="{Binding Source={x:Reference This}, Path=IsSelected}"
                    VerticalOptions="Center"
                    TextColor="{DynamicResource PrimaryColor}"
                    FontFamily="OpenSansSemibold"
                    FontSize="13" />
            </Grid>
        </Border>
    </Grid>
</ContentView>