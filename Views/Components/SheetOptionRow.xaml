<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.SheetOptionRow"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:SheetOptionRow">

	<Border
        Margin="12,0,12,8"
        Padding="14,12"
        BackgroundColor="{DynamicResource SurfaceMutedColor}"
        Stroke="{DynamicResource DividerColor}"
        StrokeThickness="1">
		<Border.StrokeShape>
			<RoundRectangle CornerRadius="16" />
		</Border.StrokeShape>

		<Border.GestureRecognizers>
			<TapGestureRecognizer
                Command="{Binding Source={x:Reference This}, Path=TapCommand}"
                CommandParameter="{Binding Source={x:Reference This}, Path=TapCommandParameter}" />
		</Border.GestureRecognizers>

		<Grid ColumnDefinitions="*,Auto">
			<Label
                Text="{Binding Source={x:Reference This}, Path=Text}"
                VerticalOptions="Center"
                Style="{StaticResource BodyLabelStyle}" />

			<Label
                Grid.Column="1"
                Text="✓"
                IsVisible="{Binding Source={x:Reference This}, Path=IsSelected}"
                VerticalOptions="Center"
                Style="{StaticResource BodyLabelStyle}" />
		</Grid>
	</Border>
</ContentView>