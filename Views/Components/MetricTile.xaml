<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.MetricTile"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:MetricTile">

    <Border
        Style="{StaticResource MetricTileBorderStyle}"
        Padding="12"
        BackgroundColor="{DynamicResource SurfaceMutedColor}"
        Stroke="{DynamicResource BorderColor}"
        StrokeThickness="1">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="14" />
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="4">
            <Label
                Text="{Binding Source={x:Reference This}, Path=Title}"
                LineBreakMode="TailTruncation"
                Style="{StaticResource MutedLabelStyle}" />

            <Label
                Text="{Binding Source={x:Reference This}, Path=Value}"
                FontFamily="OpenSansSemibold"
                FontSize="20"
                LineBreakMode="TailTruncation"
                TextColor="{DynamicResource PrimaryTextColor}" />

            <Label
                IsVisible="{Binding Source={x:Reference This}, Path=HasSubtitle}"
                Text="{Binding Source={x:Reference This}, Path=Subtitle}"
                LineBreakMode="TailTruncation"
                Style="{StaticResource MutedLabelStyle}" />
        </VerticalStackLayout>
    </Border>
</ContentView>