<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.MetricTile"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:MetricTile">

    <Border Style="{StaticResource MetricTileBorderStyle}">
        <VerticalStackLayout Spacing="3">
            <Label
                Text="{Binding Source={x:Reference This}, Path=Title}"
                Style="{StaticResource MutedLabelStyle}" />

            <Label
                Text="{Binding Source={x:Reference This}, Path=Value}"
                Style="{StaticResource BodyLabelStyle}" />

            <Label
                IsVisible="{Binding Source={x:Reference This}, Path=HasSubtitle}"
                Text="{Binding Source={x:Reference This}, Path=Subtitle}"
                Style="{StaticResource MutedLabelStyle}" />
        </VerticalStackLayout>
    </Border>
</ContentView>