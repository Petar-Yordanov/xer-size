<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.RoutineDropdown"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:RoutineDropdown">

    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
        <Grid Grid.Column="0">
            <Border
                BackgroundColor="{DynamicResource InputBackgroundColor}"
                Stroke="{DynamicResource InputBorderColor}"
                StrokeThickness="1"
                Padding="14,12"
                MinimumHeightRequest="46">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference This}, Path=TapCommand}"
                        CommandParameter="{Binding Source={x:Reference This}, Path=TapCommandParameter}" />
                </Border.GestureRecognizers>

                <Border.Behaviors>
                    <toolkit:TouchBehavior
                        IsEnabled="{Binding Source={x:Reference This}, Path=IsLongPressEnabled}"
                        LongPressDuration="650"
                        LongPressCommand="{Binding Source={x:Reference This}, Path=LongPressCommand}"
                        LongPressCommandParameter="{Binding Source={x:Reference This}, Path=LongPressCommandParameter}" />
                </Border.Behaviors>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Label
                        Text="{Binding Source={x:Reference This}, Path=SelectedText}"
                        VerticalOptions="Center"
                        LineBreakMode="TailTruncation"
                        MaxLines="1"
                        Style="{StaticResource BodyLabelStyle}" />

                    <Image
                        Grid.Column="1"
                        Source="expand_more.png"
                        WidthRequest="16"
                        HeightRequest="16"
                        Aspect="AspectFit"
                        VerticalOptions="Center"
                        HorizontalOptions="Center" />
                </Grid>
            </Border>
        </Grid>

        <Button
            Grid.Column="1"
            IsVisible="{Binding Source={x:Reference This}, Path=ShowAddButton}"
            WidthRequest="46"
            HeightRequest="46"
            CornerRadius="14"
            BackgroundColor="{DynamicResource SurfaceMutedColor}"
            BorderColor="{DynamicResource BorderColor}"
            BorderWidth="1"
            Command="{Binding Source={x:Reference This}, Path=AddCommand}"
            CommandParameter="{Binding Source={x:Reference This}, Path=AddCommandParameter}"
            ImageSource="add.png"
            Padding="12" />
    </Grid>
</ContentView>