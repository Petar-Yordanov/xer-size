<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.Card"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:Card">

    <Border
        Style="{Binding Source={x:Reference This}, Path=CardStyle}"
        StrokeShape="RoundRectangle 18"
        Padding="14"
        BackgroundColor="{DynamicResource SurfaceColor}"
        Stroke="{DynamicResource BorderColor}"
        StrokeThickness="1">
        <ContentPresenter />
    </Border>
</ContentView>