<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.TextField"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:TextField">

    <VerticalStackLayout Spacing="6">
        <Label
            IsVisible="{Binding Source={x:Reference This}, Path=HasLabel}"
            Text="{Binding Source={x:Reference This}, Path=Label}"
            Style="{StaticResource FieldLabelStyle}" />

        <Border
            BackgroundColor="{DynamicResource InputBackgroundColor}"
            Stroke="{DynamicResource InputBorderColor}"
            StrokeThickness="1"
            Padding="12,0"
            MinimumHeightRequest="46">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>

            <Entry
                Text="{Binding Source={x:Reference This}, Path=Text, Mode=TwoWay}"
                Placeholder="{Binding Source={x:Reference This}, Path=Placeholder}"
                Keyboard="{Binding Source={x:Reference This}, Path=Keyboard}"
                ClearButtonVisibility="WhileEditing"
                BackgroundColor="Transparent"
                TextColor="{DynamicResource PrimaryTextColor}"
                PlaceholderColor="{DynamicResource SecondaryTextColor}"
                VerticalOptions="Center" />
        </Border>
    </VerticalStackLayout>
</ContentView>