<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.SearchField"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:SearchField">

    <Border
        BackgroundColor="{DynamicResource InputBackgroundColor}"
        Stroke="{DynamicResource InputBorderColor}"
        StrokeThickness="1"
        Padding="12,0"
        MinimumHeightRequest="46">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="14" />
        </Border.StrokeShape>

        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
            <Image
                Source="search.png"
                WidthRequest="16"
                HeightRequest="16"
                Aspect="AspectFit"
                VerticalOptions="Center" />

            <Entry
                Grid.Column="1"
                Text="{Binding Source={x:Reference This}, Path=Text, Mode=TwoWay}"
                Placeholder="{Binding Source={x:Reference This}, Path=Placeholder}"
                ClearButtonVisibility="WhileEditing"
                BackgroundColor="Transparent"
                TextColor="{DynamicResource PrimaryTextColor}"
                PlaceholderColor="{DynamicResource SecondaryTextColor}"
                VerticalOptions="Center" />
        </Grid>
    </Border>
</ContentView>