<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Views.Components.TabChip"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XerSize.Views.Components"
    x:Name="This"
    x:DataType="local:TabChip">

    <Grid>
        <Border
            Padding="{Binding Source={x:Reference This}, Path=ChipPadding}"
            BackgroundColor="{DynamicResource SurfaceMutedColor}"
            Stroke="{DynamicResource BorderColor}"
            StrokeThickness="1"
            MinimumHeightRequest="{Binding Source={x:Reference This}, Path=ChipHeight}"
            MinimumWidthRequest="{Binding Source={x:Reference This}, Path=ChipMinWidth}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>

            <Label
                Text="{Binding Source={x:Reference This}, Path=Text}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                LineBreakMode="TailTruncation"
                MaxLines="1"
                Style="{StaticResource BodyLabelStyle}" />
        </Border>

        <Button
            BackgroundColor="Transparent"
            BorderWidth="0"
            CornerRadius="12"
            Command="{Binding Source={x:Reference This}, Path=Command}"
            CommandParameter="{Binding Source={x:Reference This}, Path=CommandParameter}" />

        <Grid.Triggers>
            <DataTrigger
                TargetType="Grid"
                Binding="{Binding Source={x:Reference This}, Path=IsSelected}"
                Value="True">
                <Setter TargetName="This" Property="Opacity" Value="1" />
            </DataTrigger>
        </Grid.Triggers>
    </Grid>
</ContentView>