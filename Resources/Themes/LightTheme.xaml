<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    x:Class="XerSize.Resources.Themes.LightTheme"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="PageBackgroundColor">#F4F6FA</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceMutedColor">#EEF2F7</Color>
    <Color x:Key="SurfaceRaisedColor">#F8FAFC</Color>
    <Color x:Key="SurfacePressedColor">#E6EBF3</Color>

    <Color x:Key="BorderColor">#D7DEE8</Color>
    <Color x:Key="BorderStrongColor">#C2CBD8</Color>
    <Color x:Key="DividerColor">#E4EAF2</Color>

    <Color x:Key="PrimaryTextColor">#0F172A</Color>
    <Color x:Key="SecondaryTextColor">#64748B</Color>
    <Color x:Key="TertiaryTextColor">#94A3B8</Color>

    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="PrimaryColorPressed">#1D4ED8</Color>
    <Color x:Key="OnPrimaryColor">#FFFFFF</Color>

    <Color x:Key="AccentSoftColor">#DBEAFE</Color>
    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="DangerColor">#DC2626</Color>

    <Color x:Key="InputBackgroundColor">#FFFFFF</Color>
    <Color x:Key="InputBorderColor">#CBD5E1</Color>
    <Color x:Key="InputBorderFocusedColor">#2563EB</Color>
    <Color x:Key="InputPlaceholderColor">#94A3B8</Color>

    <Color x:Key="OverlayScrimColor">#66000000</Color>
    <Color x:Key="DisabledBackgroundColor">#E5EAF1</Color>
    <Color x:Key="DisabledTextColor">#9AA7B7</Color>
