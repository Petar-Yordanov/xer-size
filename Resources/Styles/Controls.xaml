<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Thickness x:Key="ControlPadding">16,14</Thickness>
    <Thickness x:Key="CompactControlPadding">12,10</Thickness>

    <Style x:Key="PageRootGridStyle" TargetType="Grid">
        <Setter Property="BackgroundColor" Value="{DynamicResource PageBackgroundColor}" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="RowSpacing" Value="12" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceColor}" />
        <Setter Property="Stroke" Value="{DynamicResource BorderColor}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#12000000" Offset="0,4" Radius="14" Opacity="0.45" />
            </Setter.Value>
        </Setter>
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="20" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RaisedCardBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceRaisedColor}" />
        <Setter Property="Stroke" Value="{DynamicResource BorderStrongColor}" />
    </Style>

    <Style x:Key="MetricTileBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceMutedColor}" />
        <Setter Property="Stroke" Value="{DynamicResource DividerColor}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="16" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ChipBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceRaisedColor}" />
        <Setter Property="Stroke" Value="{DynamicResource BorderColor}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="999" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
        <Setter Property="TextColor" Value="{DynamicResource OnPrimaryColor}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="50" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceMutedColor}" />
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="BorderColor" Value="{DynamicResource BorderColor}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinimumHeightRequest" Value="46" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="TextColor" Value="{DynamicResource DangerColor}" />
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceMutedColor}" />
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="BorderColor" Value="{DynamicResource BorderColor}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WidthRequest" Value="46" />
        <Setter Property="HeightRequest" Value="46" />
        <Setter Property="MinimumHeightRequest" Value="46" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style x:Key="TextEntryStyle" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{DynamicResource InputBackgroundColor}" />
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource InputPlaceholderColor}" />
        <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
        <Setter Property="MinimumHeightRequest" Value="52" />
    </Style>

    <Style x:Key="TextEditorStyle" TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{DynamicResource InputBackgroundColor}" />
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource InputPlaceholderColor}" />
        <Setter Property="AutoSize" Value="TextChanges" />
        <Setter Property="MinimumHeightRequest" Value="108" />
    </Style>

    <Style x:Key="SearchBarStyle" TargetType="SearchBar">
        <Setter Property="BackgroundColor" Value="{DynamicResource InputBackgroundColor}" />
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource InputPlaceholderColor}" />
        <Setter Property="CancelButtonColor" Value="{DynamicResource PrimaryColor}" />
    </Style>

    <Style x:Key="AppSwitchStyle" TargetType="Switch">
        <Setter Property="OnColor" Value="{DynamicResource PrimaryColor}" />
        <Setter Property="ThumbColor" Value="{DynamicResource SurfaceColor}" />
    </Style>
</ResourceDictionary>