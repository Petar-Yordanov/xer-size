<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:XerSize.Components">

    <x:Double x:Key="RadiusXs">10</x:Double>
    <x:Double x:Key="RadiusSm">14</x:Double>
    <x:Double x:Key="RadiusMd">18</x:Double>
    <x:Double x:Key="RadiusLg">22</x:Double>
    <x:Double x:Key="RadiusXl">28</x:Double>

    <Thickness x:Key="CardPadding">18</Thickness>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource AppBackground}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource AppBackground}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource AppBackground}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Accent}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Accent}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="ClearButtonVisibility" Value="Never" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="AutoSize" Value="TextChanges" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="SectionSubtitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="{StaticResource StrokeSoft}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="28" />
            </Setter.Value>
        </Setter>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow
                    Brush="#2416A34A"
                    Offset="0,10"
                    Radius="22"
                    Opacity="0.14" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SoftCardBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceSoft}" />
        <Setter Property="Stroke" Value="{StaticResource StrokeSoft}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="22" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InputBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="{StaticResource StrokeSoft}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="18" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ChipBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceSoft}" />
        <Setter Property="Stroke" Value="{StaticResource StrokeSoft}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="999" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsToggleFieldStyle" TargetType="components:ToggleField">
        <Setter Property="FieldBackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="TrackOnColor" Value="{StaticResource AccentSoft}" />
        <Setter Property="TrackOffColor" Value="{StaticResource SurfaceMuted}" />
        <Setter Property="ThumbOnColor" Value="{StaticResource Accent}" />
        <Setter Property="ThumbOffColor" Value="{StaticResource Surface}" />
    </Style>

</ResourceDictionary>