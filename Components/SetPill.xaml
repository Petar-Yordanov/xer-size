<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="XerSize.Components.SetPill">

    <Border
        Padding="12,8"
        BackgroundColor="{Binding Source={x:Reference This}, Path=BackgroundColorValue}"
        Stroke="{Binding Source={x:Reference This}, Path=StrokeColorValue}"
        StrokeThickness="1">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="999" />
        </Border.StrokeShape>

        <Label
            Text="{Binding Source={x:Reference This}, Path=Text}"
            FontFamily="OpenSansSemibold"
            FontSize="12"
            TextColor="{Binding Source={x:Reference This}, Path=TextColorValue}"
            LineBreakMode="NoWrap"
            HorizontalTextAlignment="{Binding Source={x:Reference This}, Path=HorizontalContentAlignment}" />
    </Border>
</ContentView>