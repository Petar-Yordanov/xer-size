<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:components="clr-namespace:XerSize.Components"
    x:Class="XerSize.Components.AppActionButton"
    x:DataType="components:AppActionButton">

    <Border
        Padding="16,12"
        BackgroundColor="{Binding Source={x:Reference This}, Path=ButtonBackgroundColor}"
        Stroke="{Binding Source={x:Reference This}, Path=ButtonStrokeColor}"
        StrokeThickness="{Binding Source={x:Reference This}, Path=ButtonStrokeThickness}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="18" />
        </Border.StrokeShape>

        <Border.Shadow>
            <Shadow
                Brush="#16000000"
                Offset="0,6"
                Radius="12"
                Opacity="{Binding Source={x:Reference This}, Path=ShadowOpacity}" />
        </Border.Shadow>

        <Border.Behaviors>
            <toolkit:TouchBehavior
                PressedScale="{Binding Source={x:Reference This}, Path=PressedScale}"
                PressedOpacity="0.92"
                Command="{Binding Source={x:Reference This}, Path=Command}"
                CommandParameter="{Binding Source={x:Reference This}, Path=CommandParameter}" />
        </Border.Behaviors>

        <Label
            Text="{Binding Source={x:Reference This}, Path=Text}"
            TextColor="{Binding Source={x:Reference This}, Path=TextColor}"
            FontFamily="OpenSansSemibold"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center" />
    </Border>
</ContentView>