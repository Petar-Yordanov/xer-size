<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:components="clr-namespace:XerSize.Components"
    x:Class="XerSize.Components.NavBarItem"
    x:DataType="components:NavBarItem">

    <Grid
        WidthRequest="76"
        HorizontalOptions="Center"
        RowDefinitions="Auto,Auto"
        RowSpacing="4">

        <Border
            WidthRequest="34"
            HeightRequest="34"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="999" />
            </Border.StrokeShape>

            <Border.Behaviors>
                <toolkit:TouchBehavior PressedScale="0.92" PressedOpacity="0.90" />
            </Border.Behaviors>

            <Border.Triggers>
                <DataTrigger TargetType="Border" Binding="{Binding Source={x:Reference This}, Path=IsSelected}" Value="True">
                    <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                </DataTrigger>
                <DataTrigger TargetType="Border" Binding="{Binding Source={x:Reference This}, Path=IsSelected}" Value="False">
                    <Setter Property="BackgroundColor" Value="Transparent" />
                </DataTrigger>
            </Border.Triggers>

            <Image
                Source="{Binding Source={x:Reference This}, Path=IconSource}"
                WidthRequest="16"
                HeightRequest="16"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Aspect="AspectFit" />

            <Border.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding Source={x:Reference This}, Path=Command}"
                    CommandParameter="{Binding Source={x:Reference This}, Path=CommandParameter}" />
            </Border.GestureRecognizers>
        </Border>

        <Label
            Grid.Row="1"
            Text="{Binding Source={x:Reference This}, Path=Title}"
            FontSize="10"
            FontFamily="OpenSansSemibold"
            LineBreakMode="NoWrap"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center">
            <Label.Triggers>
                <DataTrigger TargetType="Label" Binding="{Binding Source={x:Reference This}, Path=IsSelected}" Value="True">
                    <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                </DataTrigger>
                <DataTrigger TargetType="Label" Binding="{Binding Source={x:Reference This}, Path=IsSelected}" Value="False">
                    <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
                </DataTrigger>
            </Label.Triggers>
        </Label>
    </Grid>
</ContentView>