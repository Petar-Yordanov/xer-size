<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:XerSize.Components"
    x:Class="XerSize.Components.StatusBadge"
    x:DataType="components:StatusBadge">

    <Border
        Padding="10,5"
        MinimumHeightRequest="30"
        HorizontalOptions="End"
        VerticalOptions="Start"
        BackgroundColor="{Binding Source={x:Reference This}, Path=BadgeBackgroundColor}"
        Stroke="{Binding Source={x:Reference This}, Path=BadgeStrokeColor}"
        StrokeThickness="{Binding Source={x:Reference This}, Path=BadgeStrokeThickness}">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="999" />
        </Border.StrokeShape>

        <HorizontalStackLayout
            Spacing="6"
            HorizontalOptions="Center"
            VerticalOptions="Center">

            <Border
                WidthRequest="7"
                HeightRequest="7"
                BackgroundColor="{Binding Source={x:Reference This}, Path=BadgeAccentColor}"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="999" />
                </Border.StrokeShape>
            </Border>

            <Label
                Text="{Binding Source={x:Reference This}, Path=Text}"
                TextColor="{Binding Source={x:Reference This}, Path=BadgeTextColor}"
                FontFamily="OpenSansSemibold"
                FontSize="12"
                MaxLines="1"
                LineBreakMode="NoWrap"
                VerticalTextAlignment="Center" />

        </HorizontalStackLayout>
    </Border>
</ContentView>