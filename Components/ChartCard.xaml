<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XerSize.Components.ChartCard"
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        Style="{StaticResource CardBorderStyle}"
        BackgroundColor="{Binding Source={x:Reference This}, Path=CardBackgroundColor}">

        <VerticalStackLayout Spacing="12">
            <HorizontalStackLayout Spacing="8">
                <Border
                    WidthRequest="8"
                    HeightRequest="8"
                    VerticalOptions="Center"
                    StrokeThickness="0"
                    BackgroundColor="{Binding Source={x:Reference This}, Path=DotColor}"
                    IsVisible="{Binding Source={x:Reference This}, Path=ShowDot}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="999" />
                    </Border.StrokeShape>
                </Border>

                <Label
                    Text="{Binding Source={x:Reference This}, Path=Title}"
                    FontFamily="OpenSansSemibold"
                    FontSize="16" />
            </HorizontalStackLayout>

            <ContentPresenter
                Content="{Binding Source={x:Reference This}, Path=CardContent}" />
        </VerticalStackLayout>
    </Border>
</ContentView>