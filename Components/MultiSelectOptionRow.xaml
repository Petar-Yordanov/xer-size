<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:components="clr-namespace:XerSize.Components"
    x:Class="XerSize.Components.MultiSelectOptionRow"
    x:DataType="components:MultiSelectOptionRow">

    <Border
        Margin="0,0,0,6"
        Padding="12,10"
        StrokeThickness="1">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16" />
        </Border.StrokeShape>

        <Border.Behaviors>
            <toolkit:TouchBehavior PressedScale="0.97" PressedOpacity="0.92" />
        </Border.Behaviors>

        <Border.Triggers>
            <DataTrigger TargetType="Border" Binding="{Binding Source={x:Reference This}, Path=IsSelected}" Value="True">
                <Setter Property="BackgroundColor" Value="{Binding Source={x:Reference This}, Path=SelectedBackgroundColor}" />
                <Setter Property="Stroke" Value="{Binding Source={x:Reference This}, Path=SelectedStrokeColor}" />
            </DataTrigger>
            <DataTrigger TargetType="Border" Binding="{Binding Source={x:Reference This}, Path=IsSelected}" Value="False">
                <Setter Property="BackgroundColor" Value="{Binding Source={x:Reference This}, Path=UnselectedBackgroundColor}" />
                <Setter Property="Stroke" Value="{Binding Source={x:Reference This}, Path=UnselectedStrokeColor}" />
            </DataTrigger>
        </Border.Triggers>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Label
                Text="{Binding Source={x:Reference This}, Path=Text}"
                FontFamily="OpenSansSemibold"
                FontSize="13"
                VerticalOptions="Center" />

            <Border
                Grid.Column="1"
                WidthRequest="22"
                HeightRequest="22"
                VerticalOptions="Center"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="999" />
                </Border.StrokeShape>

                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding Source={x:Reference This}, Path=IsSelected}" Value="True">
                        <Setter Property="BackgroundColor" Value="{Binding Source={x:Reference This}, Path=SelectedCheckBackgroundColor}" />
                        <Setter Property="Stroke" Value="{Binding Source={x:Reference This}, Path=SelectedCheckBackgroundColor}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding Source={x:Reference This}, Path=IsSelected}" Value="False">
                        <Setter Property="BackgroundColor" Value="{Binding Source={x:Reference This}, Path=UnselectedCheckBackgroundColor}" />
                        <Setter Property="Stroke" Value="{Binding Source={x:Reference This}, Path=UnselectedCheckStrokeColor}" />
                    </DataTrigger>
                </Border.Triggers>

                <Image
                    Source="{Binding Source={x:Reference This}, Path=CheckIconSource}"
                    WidthRequest="12"
                    HeightRequest="12"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <Image.Triggers>
                        <DataTrigger TargetType="Image" Binding="{Binding Source={x:Reference This}, Path=IsSelected}" Value="False">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Image.Triggers>
                </Image>
            </Border>
        </Grid>

        <Border.GestureRecognizers>
            <TapGestureRecognizer
                Command="{Binding Source={x:Reference This}, Path=Command}"
                CommandParameter="{Binding Source={x:Reference This}, Path=CommandParameter}" />
        </Border.GestureRecognizers>
    </Border>
</ContentView>