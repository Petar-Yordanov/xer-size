<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:XerSize.Components"
    x:Class="XerSize.Components.AppDateField"
    x:DataType="components:AppDateField">

    <VerticalStackLayout Spacing="8">
        <Label
            Text="{Binding Source={x:Reference This}, Path=Label}"
            Style="{StaticResource FieldLabelStyle}"
            IsVisible="{Binding Source={x:Reference This}, Path=HasLabel}" />

        <Border
            Style="{StaticResource InputBorderStyle}"
            BackgroundColor="{Binding Source={x:Reference This}, Path=FieldBackgroundColor}">

            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTapped" />
            </Border.GestureRecognizers>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

                <Label
                    Text="{Binding Source={x:Reference This}, Path=DateText}"
                    TextColor="{Binding Source={x:Reference This}, Path=TextColorValue}"
                    FontFamily="OpenSansSemibold"
                    FontSize="14"
                    VerticalOptions="Center"
                    LineBreakMode="NoWrap"
                    InputTransparent="True" />

                <Border
                    Grid.Column="1"
                    WidthRequest="32"
                    HeightRequest="32"
                    BackgroundColor="{Binding Source={x:Reference This}, Path=IconBackgroundColor}"
                    Stroke="{Binding Source={x:Reference This}, Path=IconStrokeColor}"
                    StrokeThickness="1"
                    Padding="8"
                    VerticalOptions="Center"
                    InputTransparent="True">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="999" />
                    </Border.StrokeShape>

                    <Image
                        Source="{Binding Source={x:Reference This}, Path=IconSource}"
                        WidthRequest="14"
                        HeightRequest="14"
                        Aspect="AspectFit"
                        IsVisible="{Binding Source={x:Reference This}, Path=HasIcon}"
                        InputTransparent="True" />
                </Border>

            </Grid>
        </Border>
    </VerticalStackLayout>
</ContentView>