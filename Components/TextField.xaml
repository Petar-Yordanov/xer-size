<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:XerSize.Components"
    x:Class="XerSize.Components.TextField"
    x:DataType="components:TextField">

    <VerticalStackLayout Spacing="8">
        <Label
            Text="{Binding Source={x:Reference This}, Path=Label}"
            Style="{StaticResource FieldLabelStyle}" />

        <Border Style="{StaticResource InputBorderStyle}">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Image
                    Source="{Binding Source={x:Reference This}, Path=IconSource}"
                    WidthRequest="18"
                    HeightRequest="18"
                    VerticalOptions="Center"
                    IsVisible="{Binding Source={x:Reference This}, Path=HasIcon}" />

                <Entry
                    Grid.Column="{Binding Source={x:Reference This}, Path=EntryColumn}"
                    Text="{Binding Source={x:Reference This}, Path=Text, Mode=TwoWay}"
                    Placeholder="{Binding Source={x:Reference This}, Path=Placeholder}" />
            </Grid>
        </Border>
    </VerticalStackLayout>
</ContentView>