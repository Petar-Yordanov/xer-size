<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:XerSize.Components"
    xmlns:behaviors="clr-namespace:XerSize.Behaviors"
    x:Class="XerSize.Components.AddWorkoutNameDialog"
    x:DataType="components:AddWorkoutNameDialog">

    <ContentView.Behaviors>
        <behaviors:AnimatedVisibilityBehavior
            IsVisibleState="{Binding Source={x:Reference This}, Path=IsOpen}"
            TranslationY="14"
            Duration="160" />
    </ContentView.Behaviors>

    <Grid InputTransparent="False">

        <BoxView
            Color="#88000000"
            HorizontalOptions="Fill"
            VerticalOptions="Fill">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding Source={x:Reference This}, Path=InternalDismissCommand}" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <Border
            Margin="20,20,20,400"
            Padding="20"
            MaximumWidthRequest="420"
            HorizontalOptions="Fill"
            VerticalOptions="Center"
            BackgroundColor="{StaticResource Surface}"
            Stroke="{StaticResource StrokeSoft}"
            StrokeThickness="1">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28" />
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow
                    Brush="#30000000"
                    Offset="0,12"
                    Radius="28"
                    Opacity="0.24" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="16">

                <Border
                    WidthRequest="48"
                    HeightRequest="48"
                    HorizontalOptions="Center"
                    BackgroundColor="{Binding Source={x:Reference This}, Path=IconBackgroundColor}"
                    StrokeThickness="0"
                    Padding="12"
                    IsVisible="{Binding Source={x:Reference This}, Path=ShowIcon}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="999" />
                    </Border.StrokeShape>

                    <Image
                        Source="{Binding Source={x:Reference This}, Path=IconSource}"
                        WidthRequest="20"
                        HeightRequest="20"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Aspect="AspectFit" />
                </Border>

                <VerticalStackLayout Spacing="6">
                    <Label
                        Text="{Binding Source={x:Reference This}, Path=Title}"
                        FontFamily="OpenSansSemibold"
                        FontSize="20"
                        TextColor="{StaticResource TextPrimary}"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="{Binding Source={x:Reference This}, Path=Message}"
                        Style="{StaticResource SectionSubtitleStyle}"
                        HorizontalTextAlignment="Center"
                        IsVisible="{Binding Source={x:Reference This}, Path=HasMessage}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="{Binding Source={x:Reference This}, Path=FieldLabel}"
                        Style="{StaticResource FieldLabelStyle}" />

                    <Border
                        Style="{StaticResource InputBorderStyle}"
                        HorizontalOptions="Fill">
                        <Entry
                            x:Name="WorkoutNameEntry"
                            HorizontalOptions="Fill"
                            Text="{Binding Source={x:Reference This}, Path=WorkoutName, Mode=TwoWay}"
                            Placeholder="{Binding Source={x:Reference This}, Path=Placeholder}"
                            ReturnType="Done"
                            ReturnCommand="{Binding Source={x:Reference This}, Path=InternalPrimaryCommand}" />
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <components:AppActionButton
                        Grid.Column="0"
                        Text="{Binding Source={x:Reference This}, Path=SecondaryButtonText}"
                        ButtonBackgroundColor="{StaticResource SurfaceSoft}"
                        ButtonStrokeColor="{StaticResource StrokeSoft}"
                        ButtonStrokeThickness="1"
                        TextColor="{StaticResource TextPrimary}"
                        ShadowOpacity="0"
                        PressedScale="0.97"
                        Command="{Binding Source={x:Reference This}, Path=InternalSecondaryCommand}" />

                    <components:AppActionButton
                        Grid.Column="1"
                        Text="{Binding Source={x:Reference This}, Path=PrimaryButtonText}"
                        ButtonBackgroundColor="{StaticResource Accent}"
                        ButtonStrokeColor="Transparent"
                        ButtonStrokeThickness="0"
                        TextColor="{StaticResource White}"
                        ShadowOpacity="0.10"
                        PressedScale="0.96"
                        Command="{Binding Source={x:Reference This}, Path=InternalPrimaryCommand}" />
                </Grid>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>