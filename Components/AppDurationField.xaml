<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:XerSize.Components"
    x:Class="XerSize.Components.AppDurationField"
    x:DataType="components:AppDurationField">

    <VerticalStackLayout Spacing="6">
        <Label
            Text="{Binding Source={x:Reference This}, Path=Label}"
            Style="{StaticResource FieldLabelStyle}"
            IsVisible="{Binding Source={x:Reference This}, Path=HasLabel}" />

        <Border
            Style="{StaticResource InputBorderStyle}"
            Padding="10,8"
            BackgroundColor="{Binding Source={x:Reference This}, Path=FieldBackgroundColor}">

            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTapped" />
            </Border.GestureRecognizers>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label
                    Text="{Binding Source={x:Reference This}, Path=DurationText}"
                    TextColor="{Binding Source={x:Reference This}, Path=TextColorValue}"
                    FontFamily="OpenSansSemibold"
                    FontSize="13"
                    HorizontalTextAlignment="Center"
                    VerticalTextAlignment="Center"
                    InputTransparent="True" />

                <Border
                    Grid.Column="1"
                    WidthRequest="28"
                    HeightRequest="28"
                    BackgroundColor="{Binding Source={x:Reference This}, Path=IconBackgroundColor}"
                    Stroke="{Binding Source={x:Reference This}, Path=IconStrokeColor}"
                    StrokeThickness="1"
                    Padding="7"
                    VerticalOptions="Center"
                    InputTransparent="True">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="999" />
                    </Border.StrokeShape>

                    <Image
                        Source="{Binding Source={x:Reference This}, Path=IconSource}"
                        WidthRequest="13"
                        HeightRequest="13"
                        Aspect="AspectFit"
                        IsVisible="{Binding Source={x:Reference This}, Path=HasIcon}"
                        InputTransparent="True" />
                </Border>
            </Grid>
        </Border>
    </VerticalStackLayout>
</ContentView>