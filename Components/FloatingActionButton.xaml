<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:components="clr-namespace:XerSize.Components"
    x:Class="XerSize.Components.FloatingActionButton"
    x:DataType="components:FloatingActionButton">

    <Border
        WidthRequest="{Binding Source={x:Reference This}, Path=ButtonSize}"
        HeightRequest="{Binding Source={x:Reference This}, Path=ButtonSize}"
        BackgroundColor="{Binding Source={x:Reference This}, Path=ButtonBackgroundColor}"
        StrokeThickness="0"
        HorizontalOptions="Center"
        VerticalOptions="Center">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="999" />
        </Border.StrokeShape>

        <Border.Shadow>
            <Shadow
                Brush="#18000000"
                Offset="0,8"
                Radius="18"
                Opacity="0.12" />
        </Border.Shadow>

        <Border.Behaviors>
            <toolkit:TouchBehavior
                PressedScale="0.92"
                PressedOpacity="0.92"
                Command="{Binding Source={x:Reference This}, Path=Command}"
                CommandParameter="{Binding Source={x:Reference This}, Path=CommandParameter}" />
        </Border.Behaviors>

        <Image
            Source="{Binding Source={x:Reference This}, Path=IconSource}"
            WidthRequest="{Binding Source={x:Reference This}, Path=IconSize}"
            HeightRequest="{Binding Source={x:Reference This}, Path=IconSize}"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Aspect="AspectFit" />
    </Border>
</ContentView>