<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Name="This"
    x:Class="XerSize.Components.AppDatePickerPopup"
    x:TypeArguments="system:DateTime"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:components="clr-namespace:XerSize.Components"
    xmlns:calendar="clr-namespace:XerSize.Models.Presentation.Calendar"
    x:DataType="components:AppDatePickerPopup">

    <Border WidthRequest="350" BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" Padding="18">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="28" />
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="#22000000" Offset="0,10" Radius="24" Opacity="0.18" />
        </Border.Shadow>

        <VerticalStackLayout Spacing="16">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Border
                    WidthRequest="38"
                    HeightRequest="38"
                    BackgroundColor="{StaticResource SurfaceSoft}"
                    Stroke="{StaticResource StrokeSoft}"
                    StrokeThickness="1"
                    Padding="10"
                    Opacity="{Binding Source={x:Reference This}, Path=PreviousMonthOpacity}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="999" />
                    </Border.StrokeShape>
                    <Image Source="left.png" WidthRequest="16" HeightRequest="16" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference This}, Path=PreviousMonthCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="{Binding Source={x:Reference This}, Path=VisibleMonthText}" FontFamily="OpenSansSemibold" FontSize="18" TextColor="{StaticResource TextPrimary}" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding Source={x:Reference This}, Path=SelectedDateText}" Style="{StaticResource SectionSubtitleStyle}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Border
                    Grid.Column="2"
                    WidthRequest="38"
                    HeightRequest="38"
                    BackgroundColor="{StaticResource SurfaceSoft}"
                    Stroke="{StaticResource StrokeSoft}"
                    StrokeThickness="1"
                    Padding="10"
                    Opacity="{Binding Source={x:Reference This}, Path=NextMonthOpacity}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="999" />
                    </Border.StrokeShape>
                    <Image Source="right.png" WidthRequest="16" HeightRequest="16" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference This}, Path=NextMonthCommand}" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <VerticalStackLayout Spacing="12">
                <VerticalStackLayout.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnCalendarPanUpdated" />
                </VerticalStackLayout.GestureRecognizers>

                <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="4">
                    <Label Grid.Column="0" Text="Mon" Style="{StaticResource FieldLabelStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="1" Text="Tue" Style="{StaticResource FieldLabelStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="2" Text="Wed" Style="{StaticResource FieldLabelStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="3" Text="Thu" Style="{StaticResource FieldLabelStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="4" Text="Fri" Style="{StaticResource FieldLabelStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="5" Text="Sat" Style="{StaticResource FieldLabelStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="6" Text="Sun" Style="{StaticResource FieldLabelStyle}" HorizontalTextAlignment="Center" />
                </Grid>

                <CollectionView x:Name="DaysCollection" ItemsSource="{Binding Source={x:Reference This}, Path=Days}" SelectionMode="None" HeightRequest="258">
                    <CollectionView.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnCalendarPanUpdated" />
                    </CollectionView.GestureRecognizers>

                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="7" HorizontalItemSpacing="5" VerticalItemSpacing="7" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="calendar:CalendarDayPresentationModel">
                            <Border WidthRequest="38" HeightRequest="36" BackgroundColor="Transparent" Stroke="Transparent" StrokeThickness="1" Padding="0" HorizontalOptions="Center" VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>

                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsToday}" Value="True">
                                        <Setter Property="Stroke" Value="{StaticResource AccentSoft}" />
                                        <Setter Property="BackgroundColor" Value="{StaticResource AccentSurface}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                                        <Setter Property="Stroke" Value="{StaticResource Accent}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsEnabled}" Value="False">
                                        <Setter Property="Opacity" Value="0.28" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Label Text="{Binding DayText}" TextColor="{StaticResource TextPrimary}" FontFamily="OpenSansSemibold" FontSize="13" HorizontalTextAlignment="Center" VerticalTextAlignment="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsCurrentMonth}" Value="False">
                                            <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsEnabled}" Value="False">
                                            <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="TextColor" Value="{StaticResource White}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnDayTapped" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <components:AppActionButton Grid.Column="0" Text="Cancel" ButtonBackgroundColor="{StaticResource SurfaceSoft}" ButtonStrokeColor="{StaticResource StrokeSoft}" ButtonStrokeThickness="1" TextColor="{StaticResource TextPrimary}" ShadowOpacity="0" PressedScale="0.97" Command="{Binding Source={x:Reference This}, Path=CancelCommand}" />
                <components:AppActionButton Grid.Column="1" Text="Apply" ButtonBackgroundColor="{StaticResource Accent}" ButtonStrokeColor="Transparent" ButtonStrokeThickness="0" TextColor="{StaticResource White}" ShadowOpacity="0.10" PressedScale="0.96" Command="{Binding Source={x:Reference This}, Path=ApplyCommand}" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>