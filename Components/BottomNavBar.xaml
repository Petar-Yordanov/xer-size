<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:XerSize.Components"
    x:Class="XerSize.Components.BottomNavBar"
    x:DataType="components:BottomNavBar">

    <Grid HeightRequest="96" InputTransparent="False">
        <Border
            IsVisible="{Binding Source={x:Reference This}, Path=ShowCenterButton}"
            WidthRequest="{Binding Source={x:Reference This}, Path=CenterHaloOuterSize}"
            HeightRequest="{Binding Source={x:Reference This}, Path=CenterHaloOuterSize}"
            BackgroundColor="{StaticResource White}"
            Stroke="{StaticResource StrokeSoft}"
            StrokeThickness="1"
            HorizontalOptions="Center"
            VerticalOptions="Start"
            TranslationY="-7"
            ZIndex="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="999" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#18000000" Offset="0,8" Radius="18" Opacity="0.12" />
            </Border.Shadow>
        </Border>

        <Border
            Margin="0,10,0,0"
            Background="{Binding Source={x:Reference This}, Path=BarBackgroundColor}"
            Stroke="{Binding Source={x:Reference This}, Path=BarStrokeColor}"
            StrokeThickness="1"
            Padding="16,10,16,8"
            ZIndex="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="999" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="{Binding Source={x:Reference This}, Path=BarShadowBrush}" Offset="0,8" Radius="18" Opacity="0.12" />
            </Border.Shadow>

            <Grid ColumnDefinitions="1*,1*,88,1*,1*" ColumnSpacing="0" VerticalOptions="Center">
                <components:NavBarItem
                    Grid.Column="0"
                    Title="{Binding Source={x:Reference This}, Path=LeftPrimaryItem.Name}"
                    IconSource="{Binding Source={x:Reference This}, Path=LeftPrimaryItem.IconSource}"
                    IsSelected="{Binding Source={x:Reference This}, Path=LeftPrimaryItem.IsSelected}"
                    Command="{Binding Source={x:Reference This}, Path=ItemCommand}"
                    CommandParameter="{Binding Source={x:Reference This}, Path=LeftPrimaryItem}" />

                <components:NavBarItem
                    Grid.Column="1"
                    Title="{Binding Source={x:Reference This}, Path=LeftSecondaryItem.Name}"
                    IconSource="{Binding Source={x:Reference This}, Path=LeftSecondaryItem.IconSource}"
                    IsSelected="{Binding Source={x:Reference This}, Path=LeftSecondaryItem.IsSelected}"
                    Command="{Binding Source={x:Reference This}, Path=ItemCommand}"
                    CommandParameter="{Binding Source={x:Reference This}, Path=LeftSecondaryItem}" />

                <components:NavBarItem
                    Grid.Column="3"
                    Title="{Binding Source={x:Reference This}, Path=RightPrimaryItem.Name}"
                    IconSource="{Binding Source={x:Reference This}, Path=RightPrimaryItem.IconSource}"
                    IsSelected="{Binding Source={x:Reference This}, Path=RightPrimaryItem.IsSelected}"
                    Command="{Binding Source={x:Reference This}, Path=ItemCommand}"
                    CommandParameter="{Binding Source={x:Reference This}, Path=RightPrimaryItem}" />

                <components:NavBarItem
                    Grid.Column="4"
                    Title="{Binding Source={x:Reference This}, Path=RightSecondaryItem.Name}"
                    IconSource="{Binding Source={x:Reference This}, Path=RightSecondaryItem.IconSource}"
                    IsSelected="{Binding Source={x:Reference This}, Path=RightSecondaryItem.IsSelected}"
                    Command="{Binding Source={x:Reference This}, Path=ItemCommand}"
                    CommandParameter="{Binding Source={x:Reference This}, Path=RightSecondaryItem}" />
            </Grid>
        </Border>

        <Border
            IsVisible="{Binding Source={x:Reference This}, Path=ShowCenterButton}"
            WidthRequest="{Binding Source={x:Reference This}, Path=CenterHaloInnerSize}"
            HeightRequest="{Binding Source={x:Reference This}, Path=CenterHaloInnerSize}"
            BackgroundColor="{StaticResource White}"
            StrokeThickness="0"
            HorizontalOptions="Center"
            VerticalOptions="Start"
            TranslationY="-5"
            ZIndex="2">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="999" />
            </Border.StrokeShape>
        </Border>

        <components:FloatingActionButton
            IsVisible="{Binding Source={x:Reference This}, Path=ShowCenterButton}"
            IconSource="{Binding Source={x:Reference This}, Path=CenterIconSource}"
            Command="{Binding Source={x:Reference This}, Path=CenterCommand}"
            CommandParameter="{Binding Source={x:Reference This}, Path=CenterCommandParameter}"
            ButtonBackgroundColor="{Binding Source={x:Reference This}, Path=CenterButtonBackgroundColor}"
            ButtonSize="{Binding Source={x:Reference This}, Path=CenterButtonSize}"
            IconSize="{Binding Source={x:Reference This}, Path=CenterIconSize}"
            HorizontalOptions="Center"
            VerticalOptions="Start"
            TranslationY="0"
            ZIndex="3" />
    </Grid>
</ContentView>